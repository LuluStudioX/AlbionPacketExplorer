<controls:ApxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
        xmlns:vm="clr-namespace:AlbionPacketExplorer.ViewModels"
        x:Class="AlbionPacketExplorer.Views.DiagnosticsWindow"
        x:DataType="vm:DiagnosticsViewModel"
        Icon="/Assets/app-icon.ico"
        Title="Diagnostics"
        Width="720" Height="620"
        MinWidth="460" MinHeight="380"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="14" LastChildFill="True">

        <!-- Live process metrics -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Apx.Card}"
                BorderBrush="{DynamicResource Apx.Border}" BorderThickness="1"
                CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" >
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Memory" Margin="0,0,12,4"
                           Foreground="{DynamicResource Apx.TextMuted}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MemoryText}" Margin="0,0,0,4"
                           FontFamily="Monospace" Foreground="{DynamicResource Apx.Text}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU" Margin="0,0,12,4"
                           Foreground="{DynamicResource Apx.TextMuted}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CpuText}" Margin="0,0,0,4"
                           FontFamily="Monospace" Foreground="{DynamicResource Apx.Text}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="GC" Margin="0,0,12,4"
                           Foreground="{DynamicResource Apx.TextMuted}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GcText}" Margin="0,0,0,4"
                           FontFamily="Monospace" Foreground="{DynamicResource Apx.Text}" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Threads" Margin="0,0,12,0"
                           Foreground="{DynamicResource Apx.TextMuted}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ThreadsText}"
                           FontFamily="Monospace" Foreground="{DynamicResource Apx.Text}" />
            </Grid>
        </Border>

        <!-- Last load timing breakdown -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Apx.Card}"
                BorderBrush="{DynamicResource Apx.Border}" BorderThickness="1"
                CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Last load" Margin="0,0,0,6"
                           Foreground="{DynamicResource Apx.TextMuted}" />
                <TextBlock Text="{Binding LoadSummary}" FontFamily="Monospace"
                           Foreground="{DynamicResource Apx.Text}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <CheckBox IsChecked="{Binding Verbose}" Content="Verbose logging"
                      Foreground="{DynamicResource Apx.Text}" VerticalAlignment="Center" />
            <Border Width="1" Background="{DynamicResource Apx.Border}" Margin="4,2" />
            <Button Content="Force GC" Command="{Binding ForceGcCommand}" />
            <Button Content="Copy log" Command="{Binding CopyLogCommand}" />
            <Button Content="Clear" Command="{Binding ClearLogCommand}" />
            <Button Content="Open logs folder" Command="{Binding OpenLogsFolderCommand}" />
        </StackPanel>

        <!-- App log -->
        <Border Background="{DynamicResource Apx.Surface}"
                BorderBrush="{DynamicResource Apx.Border}" BorderThickness="1" CornerRadius="6">
            <ScrollViewer Name="LogScroller" Padding="8">
                <ItemsControl ItemsSource="{Binding Log}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Monospace" FontSize="11"
                                       Foreground="{DynamicResource Apx.Text}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</controls:ApxWindow>
