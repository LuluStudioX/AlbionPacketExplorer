<controls:ApxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
        x:Class="AlbionPacketExplorer.Views.ExpandedValueWindow"
        Title="Full Value"
        Width="640" Height="460"
        MinWidth="320" MinHeight="200"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Margin="16">
        <TextBox x:Name="ValueBox"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontFamily="Monospace"
                 BorderThickness="0"
                 Background="Transparent" />
    </ScrollViewer>
</controls:ApxWindow>
