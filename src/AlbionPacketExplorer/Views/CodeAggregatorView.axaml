<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AlbionPacketExplorer.ViewModels"
             xmlns:views="using:AlbionPacketExplorer.Views"
             xmlns:loc="using:AlbionPacketExplorer.Markup"
             x:Class="AlbionPacketExplorer.Views.CodeAggregatorView"
             x:DataType="vm:CodeAggregatorViewModel">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="4,2">
            <ToggleButton IsChecked="{Binding SortUnknownFirst, Mode=TwoWay}" Padding="8,3"
                          ToolTip.Tip="{loc:T summary.unknownFirst.tip}">
                <TextBlock Text="{loc:T summary.unknownFirst}" FontSize="11" VerticalAlignment="Center" />
            </ToggleButton>
            <TextBlock Text="{Binding CoverageText}" FontSize="11" VerticalAlignment="Center"
                       Foreground="{DynamicResource Apx.TextMuted}" />
        </StackPanel>

        <Grid RowDefinitions="2*,Auto,*">

        <DataGrid x:Name="MainGrid" Grid.Row="0" ItemsSource="{Binding CodeStats}"
                  FontSize="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Styles>
                <Style Selector="DataGridRow">
                    <Setter Property="MinHeight"
                            Value="{Binding $parent[Window].((vm:MainViewModel)DataContext).RowHeight, FallbackValue=24}" />
                </Style>
                <Style Selector="DataGridCell TextBlock">
                    <Setter Property="FontSize"
                            Value="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{loc:T summary.menu.copyKeys}"          Command="{Binding CopyKeySummaryCommand}" />
                    <MenuItem Header="{loc:T summary.menu.exportStub}" Command="{Binding ExportCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>

                <DataGridTemplateColumn Width="80" SortMemberPath="Kind" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{loc:T summary.col.kind}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterKind, Mode=TwoWay}"
                                                 PlaceholderText="{loc:T summary.filterKind.placeholder}" Width="160" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:CodeStatsRow">
                            <TextBlock Text="{Binding Kind}" Margin="12,0" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="60" SortMemberPath="Code" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{loc:T summary.col.code}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterCode, Mode=TwoWay}"
                                                 PlaceholderText="{loc:T summary.filterCode.placeholder}" Width="160" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:CodeStatsRow">
                            <TextBlock Text="{Binding Code}" Margin="12,0" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="180" SortMemberPath="EventName" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{loc:T summary.col.name}" VerticalAlignment="Center" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:CodeStatsRow">
                            <TextBlock Margin="12,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       Text="{Binding EventName}"
                                       Opacity="{Binding IsKnown, Converter={x:Static views:ViewConverters.BoolToOpacity}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="80" SortMemberPath="Count" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{loc:T summary.col.count}" VerticalAlignment="Center" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:CodeStatsRow">
                            <TextBlock Text="{Binding Count}" Margin="12,0" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="*" SortMemberPath="KeySummary" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{loc:T summary.col.keys}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterKeys, Mode=TwoWay}"
                                                 PlaceholderText="{loc:T summary.filterKeys.placeholder}" Width="240" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:CodeStatsRow">
                            <TextBlock Text="{Binding KeySummary}" Margin="12,0" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                      ResizeDirection="Rows" Background="{DynamicResource Apx.Border}" />

        <!-- Field-value distribution for the selected code (#1): how each byte key's value varies. -->
        <DockPanel Grid.Row="2">
            <TextBlock DockPanel.Dock="Top" Margin="6,4,6,2" FontWeight="SemiBold"
                       Text="{loc:T summary.fields.title}"
                       Foreground="{DynamicResource Apx.TextMuted}" />
            <!-- Per-code note (#9): persisted findings about the selected code. -->
            <Grid DockPanel.Dock="Top" Margin="6,0,6,4" ColumnDefinitions="*,Auto"
                  IsVisible="{Binding HasSelectedKeyStats}">
                <TextBox Grid.Column="0" Text="{Binding NoteDraft, Mode=TwoWay}"
                         PlaceholderText="{loc:T summary.note.placeholder}"
                         AcceptsReturn="True" MaxLength="2000" MaxHeight="80"
                         TextWrapping="Wrap" FontSize="12" />
                <Button Grid.Column="1" Classes="ghost" VerticalAlignment="Top" Margin="6,0,0,0"
                        Command="{Binding SaveNoteCommand}" Content="{loc:T summary.note.save}" />
            </Grid>
            <TextBlock Text="{loc:T summary.fields.empty}" Margin="8"
                       Foreground="{DynamicResource Apx.TextMuted}" TextWrapping="Wrap"
                       IsVisible="{Binding !HasSelectedKeyStats}" />
            <DataGrid ItemsSource="{Binding SelectedKeyStats}"
                      IsVisible="{Binding HasSelectedKeyStats}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserSortColumns="True" CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      FontSize="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:T summary.field.col.key}"      Binding="{Binding Key}" Width="60" />
                    <DataGridTextColumn Header="{loc:T summary.field.col.present}"  Binding="{Binding PresencePct, StringFormat='{}{0:0}%'}" Width="80" />
                    <DataGridTextColumn Header="{loc:T summary.field.col.types}"    Binding="{Binding TypesDisplay}" Width="120" />
                    <DataGridTextColumn Header="{loc:T summary.field.col.distinct}" Binding="{Binding DistinctDisplay}" Width="80" />
                    <DataGridTextColumn Header="{loc:T summary.field.col.range}"    Binding="{Binding MinMaxDisplay}" Width="150" />
                    <DataGridTextColumn Header="{loc:T summary.field.col.guess}"    Binding="{Binding Heuristic}" Width="120" />
                    <DataGridTextColumn Header="{loc:T summary.field.col.top}"      Binding="{Binding TopValuesDisplay}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        </Grid>
    </DockPanel>

</UserControl>
