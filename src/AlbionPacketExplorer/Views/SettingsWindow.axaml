<controls:ApxWindow xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
                xmlns:views="clr-namespace:AlbionPacketExplorer.Views"
                xmlns:vm="using:AlbionPacketExplorer.ViewModels"
                xmlns:loc="using:AlbionPacketExplorer.Markup"
                x:Class="AlbionPacketExplorer.Views.SettingsWindow"
                x:DataType="vm:SettingsViewModel"
                Title="{loc:T settings.title}"
                Icon="/Assets/app-icon.ico"
                Width="800" Height="640"
                MinWidth="640" MinHeight="420"
                CanResize="True"
                WindowStartupLocation="CenterOwner">

    <Grid ColumnDefinitions="2*,8*" ClipToBounds="True">

        <!-- Left nav -->
        <Border Grid.Column="0" Background="{DynamicResource Apx.Surface}" Padding="0,8"
                BorderBrush="{DynamicResource Apx.Border}" BorderThickness="0,0,1,0">
            <StackPanel Spacing="2">
                <Button Name="NavDisplay"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Display">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Monitor}" />
                        <TextBlock Text="{loc:T settings.nav.display}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavCapture"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Capture">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Radio}" />
                        <TextBlock Text="{loc:T settings.nav.capture}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavShortcuts"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Shortcuts">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Layers}" />
                        <TextBlock Text="{loc:T settings.nav.shortcuts}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavPaths"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Paths">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Folder}" />
                        <TextBlock Text="{loc:T settings.nav.paths}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavSchema"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Schema">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.FileCode}" />
                        <TextBlock Text="{loc:T settings.nav.schema}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavProtocol"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Protocol">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Globe}" />
                        <TextBlock Text="{loc:T settings.nav.protocol}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavTheme"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Theme">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Palette}" />
                        <TextBlock Text="{loc:T settings.nav.theme}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavGlossary"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Glossary">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.HelpCircle}" />
                        <TextBlock Text="{loc:T settings.nav.glossary}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavAbout"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="About">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Info}" />
                        <TextBlock Text="{loc:T settings.nav.about}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Right content -->
        <!-- Always reserve the scrollbar gutter (AllowAutoHide=False) so card widths are
             identical whether or not a tab scrolls. -->
        <!-- Proportional layout: equal left/right gutters that scale with the window so cards
             keep the same margins on every tab. Vertical scrollbar always visible so its gutter
             is reserved identically whether or not a tab scrolls. -->
        <ScrollViewer Grid.Column="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Visible">
            <Grid ColumnDefinitions="6*,88*,6*">
                <StackPanel Grid.Column="1" Spacing="16" Margin="0,20,0,24"
                            HorizontalAlignment="Stretch">

                <!-- Display section -->
                <StackPanel Name="SectionDisplay" Spacing="12">
                    <TextBlock Text="{loc:T settings.nav.display}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.resolveNames}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.resolveNames.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.resolveNames.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ResolveItemNames}"
                                         IsEnabled="{Binding GameDataLoaded}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.density}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.density.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DensityOptions}"
                                      SelectedItem="{Binding Density}"
                                      MinWidth="140"
                                      VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.resolveIcons}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.resolveIcons.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.iconMode.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding IconModeOptions}"
                                      SelectedItem="{Binding IconMode}"
                                      IsEnabled="{Binding GameDataLoaded}"
                                      MinWidth="120"
                                      VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.forceExpand}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.forceExpand.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.forceExpand.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ForceExpandRows}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Capture section -->
                <StackPanel Name="SectionCapture" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.capture.title}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.autoStart}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.autoStart.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.autoStart.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding AutoStartCapture}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.autoSave}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.autoSave.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.autoSave.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding AutoSaveLogs}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.tray}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.tray.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding MinimizeToTray}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Protocol Scanner section -->
                <StackPanel Name="SectionProtocol" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.protocol.title}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{loc:T settings.protocol.hint}"
                               Foreground="Gray" FontSize="12" TextWrapping="Wrap" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.protocol.enable}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.protocol.enable.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding ProtocolScan.Enabled}"
                                          VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <!-- Everything below is gated on the feature being enabled. -->
                    <StackPanel Spacing="12" IsVisible="{Binding ProtocolScan.Enabled}">

                        <Border Classes="card" Padding="16">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="{loc:T settings.protocol.startup}" FontWeight="SemiBold" />
                                    <TextBlock Text="{loc:T settings.protocol.startup.desc}"
                                               Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding ProtocolScan.ScanOnStartup}"
                                              VerticalAlignment="Center" Margin="20,0,0,0" />
                            </Grid>
                        </Border>

                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{loc:T settings.protocol.path}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.protocol.path.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ProtocolScan.ClientPathOverride}"
                                             Watermark="{loc:T settings.protocol.path.auto}" />
                                    <Button Grid.Column="1" Classes="ghost"
                                            Content="{loc:T settings.protocol.browse}"
                                            Command="{Binding ProtocolScan.BrowseClientCommand}" />
                                    <Button Grid.Column="2" Classes="ghost"
                                            Content="{loc:T settings.protocol.clear}"
                                            Command="{Binding ProtocolScan.ClearClientPathCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{loc:T settings.protocol.webhook}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.protocol.webhook.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding ProtocolScan.Webhooks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WebhookEntryViewModel">
                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,6">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Url}"
                                                         LostFocus="OnWebhookFieldLostFocus"
                                                         Watermark="https://discord.com/api/webhooks/..." />
                                                <Button Grid.Column="1" Classes="ghost"
                                                        Content="{loc:T settings.protocol.test}"
                                                        IsEnabled="{Binding HasUrl}"
                                                        Command="{Binding TestCommand}" />
                                                <Button Grid.Column="2" Classes="ghost"
                                                        Content="{loc:T settings.protocol.webhook.remove}"
                                                        Command="{Binding RemoveCommand}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Classes="ghost" HorizontalAlignment="Left"
                                        Content="{loc:T settings.protocol.webhook.add}"
                                        Command="{Binding ProtocolScan.AddWebhookCommand}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="3">
                                        <TextBlock Text="{loc:T settings.protocol.scan}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProtocolScan.StatusText}"
                                                   Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="accent"
                                            Content="{loc:T settings.protocol.scanNow}"
                                            IsEnabled="{Binding !ProtocolScan.IsScanning}"
                                            Command="{Binding ProtocolScan.ScanCommand}"
                                            VerticalAlignment="Center" Margin="20,0,0,0" />
                                </Grid>

                                <StackPanel Spacing="6" IsVisible="{Binding ProtocolScan.HasResult}">
                                    <TextBlock Text="{Binding ProtocolScan.Summary}" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding ProtocolScan.Changes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ProtocolChangeRow">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,2">
                                                    <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                               FontFamily="Cascadia Code,Consolas,monospace"
                                                               Foreground="{DynamicResource Apx.Accent}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                               FontFamily="Cascadia Code,Consolas,monospace"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                                               Foreground="Gray" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                        <TextBlock Grid.Column="0"
                                                   Text="{loc:T settings.protocol.submit.desc}"
                                                   Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Classes="ghost"
                                                Content="{loc:T settings.protocol.submit}"
                                                IsEnabled="{Binding ProtocolScan.CanSubmitToCloud}"
                                                Command="{Binding ProtocolScan.SubmitToCloudCommand}"
                                                VerticalAlignment="Center" Margin="12,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{loc:T settings.protocol.privacy}"
                                   Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                    </StackPanel>
                </StackPanel>

                <!-- Shortcuts section -->
                <StackPanel Name="SectionShortcuts" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.shortcuts}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{loc:T settings.shortcuts.hint}"
                               Foreground="Gray" FontSize="12" TextWrapping="Wrap" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.shortcuts.sidebar}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.shortcuts.sidebar.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <controls:GestureCaptureBox Grid.Column="1"
                                                        Gesture="{Binding SidebarToggleGesture, Mode=TwoWay}"
                                                        MinWidth="120"
                                                        VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.shortcuts.autoSelect}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.shortcuts.autoSelect.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <controls:GestureCaptureBox Grid.Column="1"
                                                        Gesture="{Binding AutoSelectNewestGesture, Mode=TwoWay}"
                                                        MinWidth="120"
                                                        VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.shortcuts.rowExpand}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.shortcuts.rowExpand.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <controls:GestureCaptureBox Grid.Column="1"
                                                        Gesture="{Binding ToggleRowExpandGesture, Mode=TwoWay}"
                                                        MinWidth="120"
                                                        VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Paths section -->
                <StackPanel Name="SectionPaths" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.paths}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.paths.appData}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.paths.appData.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            <Border Classes="pathchip">
                                <SelectableTextBlock Text="{Binding DataFolderPath}"
                                                     FontFamily="Consolas,Monospace" FontSize="11"
                                                     HorizontalAlignment="Center" TextAlignment="Center" />
                            </Border>
                            <TextBlock Text="{loc:T settings.paths.changeNote}"
                                       Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Classes="ghost" Command="{Binding ChangeDataFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Folder}" />
                                        <TextBlock Text="{loc:T settings.paths.change}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding OpenDataFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                        <TextBlock Text="{loc:T settings.paths.openInExplorer}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.paths.logFolder}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.paths.logFolder.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            <Border Classes="pathchip">
                                <SelectableTextBlock Text="{Binding SatPacketSnifferPath}"
                                                     FontFamily="Consolas,Monospace" FontSize="11"
                                                     HorizontalAlignment="Center" TextAlignment="Center" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Classes="ghost" Command="{Binding ChangeLogFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Folder}" />
                                        <TextBlock Text="{loc:T settings.paths.change}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding OpenSatFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                        <TextBlock Text="{loc:T settings.paths.openInExplorer}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.paths.itemCache}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.paths.itemCache.desc}"
                                       Foreground="Gray" FontSize="12" />
                            <Border Classes="pathchip">
                                <SelectableTextBlock Text="{Binding ItemCachePath}"
                                                     FontFamily="Consolas,Monospace" FontSize="11"
                                                     HorizontalAlignment="Center" TextAlignment="Center" />
                            </Border>
                            <TextBlock Text="{loc:T settings.paths.itemCache.customNote}"
                                       Foreground="{DynamicResource Apx.Warning}" FontSize="11" TextWrapping="Wrap"
                                       IsVisible="{Binding ItemCacheIsCustom}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Classes="ghost" Command="{Binding ChangeItemCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Folder}" />
                                        <TextBlock Text="{loc:T settings.paths.change}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding OpenItemCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                        <TextBlock Text="{loc:T settings.paths.openInExplorer}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.paths.iconCache}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.paths.iconCache.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            <Border Classes="pathchip">
                                <SelectableTextBlock Text="{Binding IconCachePath}"
                                                     FontFamily="Consolas,Monospace" FontSize="11"
                                                     HorizontalAlignment="Center" TextAlignment="Center" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Classes="ghost" Command="{Binding ChangeIconCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Folder}" />
                                        <TextBlock Text="{loc:T settings.paths.change}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding OpenIconCacheFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                        <TextBlock Text="{loc:T settings.paths.openInExplorer}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding FindExistingIconsCommand}"
                                        IsEnabled="{Binding IsScanningIcons, Converter={x:Static BoolConverters.Not}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <controls:ApxSpinner Width="12" Height="12" IsVisible="{Binding IsScanningIcons}" />
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Search}"
                                              IsVisible="{Binding IsScanningIcons, Converter={x:Static BoolConverters.Not}}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{loc:T settings.paths.findIcons}"
                                                   IsVisible="{Binding IsScanningIcons, Converter={x:Static BoolConverters.Not}}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{loc:T settings.paths.findIcons.scanning}"
                                                   IsVisible="{Binding IsScanningIcons}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Detected icon folders -->
                            <TextBlock Text="{loc:T settings.paths.findIcons.none}"
                                       Foreground="Gray" FontSize="11" Margin="0,4,0,0">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="IconScanDone" />
                                        <Binding Path="IconCandidates.Count" Converter="{x:Static views:ViewConverters.IsZero}" />
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding IconCandidates}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                            <SelectableTextBlock Grid.Column="0" Text="{Binding Path}"
                                                                 FontFamily="Consolas,Monospace" FontSize="11"
                                                                 VerticalAlignment="Center" TextWrapping="Wrap"
                                                                 Foreground="{DynamicResource Apx.TextMuted}" />
                                            <Button Grid.Column="1" Classes="ghost" Margin="8,0,0,0"
                                                    Command="{Binding $parent[ItemsControl].DataContext.UseIconCandidateCommand}"
                                                    CommandParameter="{Binding}"
                                                    Content="{Binding IconCount, StringFormat='Use ({0})'}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Schema Export section -->
                <StackPanel Name="SectionSchema" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.schema}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{loc:T settings.schema.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="Auto,8,120,8,Auto,8,*">
                                <TextBlock Grid.Column="0" Text="{loc:T settings.schema.kind}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="2" SelectedItem="{Binding ExportKind}">
                                    <ComboBoxItem Content="EVENT" />
                                    <ComboBoxItem Content="REQUEST" />
                                    <ComboBoxItem Content="RESPONSE" />
                                </ComboBox>
                                <TextBlock Grid.Column="4" Text="{loc:T settings.schema.code}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="6" Text="{Binding ExportCode}"
                                         PlaceholderText="{loc:T settings.schema.code.placeholder}" MaxLength="5" />
                            </Grid>

                            <TextBox Text="{Binding ExportPreview}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas,Monospace"
                                     FontSize="11"
                                     AcceptsReturn="True"
                                     Height="200"
                                     TextWrapping="NoWrap"
                                     PlaceholderText="{loc:T settings.schema.preview.placeholder}" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="ghost" Command="{Binding CopyExportCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Copy}" />
                                        <TextBlock Text="{loc:T settings.schema.copy}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding SaveExportCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Save}" />
                                        <TextBlock Text="{loc:T settings.schema.save}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Theme section -->
                <StackPanel Name="SectionTheme" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.theme}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.theme.dark}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.theme.dark.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding IsDarkMode}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{loc:T settings.theme.color}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.theme.color.desc}"
                                       Foreground="Gray" FontSize="12" />
                            <ListBox ItemsSource="{Binding AvailableThemes}"
                                     SelectedItem="{Binding SelectedTheme}"
                                     SelectionMode="Single"
                                     Background="Transparent" BorderThickness="0">
                                <ListBox.Styles>
                                    <!-- No blue selection chrome; the swatch shows selection via
                                         its own accent ring + check instead. -->
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Selected swatch: accent ring + black label (unselected
                                             swatches use white) so the active accent reads clearly. -->
                                        <Border CornerRadius="9" Margin="4" Padding="3"
                                                BorderThickness="2" BorderBrush="Transparent">
                                            <Border.Styles>
                                                <Style Selector="ListBoxItem:selected Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Apx.Text}" />
                                                </Style>
                                            </Border.Styles>
                                            <Border Width="80" Height="36" CornerRadius="6"
                                                    Background="{Binding AccentBrush}">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="White">
                                                    <TextBlock.Styles>
                                                        <Style Selector="ListBoxItem:selected TextBlock">
                                                            <Setter Property="Foreground" Value="Black" />
                                                        </Style>
                                                    </TextBlock.Styles>
                                                </TextBlock>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.theme.language}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.theme.language.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCultures}"
                                      SelectedItem="{Binding Culture}"
                                      MinWidth="120"
                                      VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- Glossary section -->
                <StackPanel Name="SectionGlossary" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.glossary}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{loc:T glossary.intro}"
                               Foreground="Gray" FontSize="12" TextWrapping="Wrap" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.packet.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.packet.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.event.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.event.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.request.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.request.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.response.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.response.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.code.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.code.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.key.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.key.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.param.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.param.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.resolve.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.resolve.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{loc:T glossary.schema.term}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Apx.Accent}" />
                                <TextBlock Text="{loc:T glossary.schema.def}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- About section -->
                <StackPanel Name="SectionAbout" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.about}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.about.name}" FontWeight="Bold" FontSize="15" />
                            <TextBlock Text="{Binding Version}" Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{loc:T settings.about.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />

                            <!-- Update controls (moved here from the toolbar). -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button Command="{Binding CheckForUpdateCommand}"
                                        IsEnabled="{Binding IsCheckingUpdate, Converter={x:Static BoolConverters.Not}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <controls:ApxSpinner Width="12" Height="12" IsVisible="{Binding IsCheckingUpdate}" />
                                        <TextBlock Text="{loc:T settings.about.checkUpdate}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="success" Command="{Binding ApplyUpdateCommand}"
                                        IsVisible="{Binding HasUpdate}"
                                        IsEnabled="{Binding IsUpdating, Converter={x:Static BoolConverters.Not}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <controls:ApxSpinner Width="12" Height="12" IsVisible="{Binding IsUpdating}" />
                                        <TextBlock Text="{loc:T settings.about.applyUpdate}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding UpdateStatus}" Foreground="Gray" FontSize="12" TextWrapping="Wrap"
                                       IsVisible="{Binding UpdateStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
            </Grid>
        </ScrollViewer>

    </Grid>

</controls:ApxWindow>
