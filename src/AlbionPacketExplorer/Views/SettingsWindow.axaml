<controls:ApxWindow xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
                xmlns:vm="using:AlbionPacketExplorer.ViewModels"
                x:Class="AlbionPacketExplorer.Views.SettingsWindow"
                x:DataType="vm:SettingsViewModel"
                Title="Settings"
                Icon="/Assets/app-icon.ico"
                Width="680"
                MinWidth="500" MinHeight="400"
                MaxHeight="700"
                SizeToContent="Height"
                CanResize="True">

    <Grid ColumnDefinitions="180,*">

        <!-- Left nav -->
        <Border Grid.Column="0" Background="{DynamicResource Apx.Surface}" Padding="0,8">
            <StackPanel Spacing="2">
                <Button Name="NavDisplay"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Display">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Monitor}" />
                        <TextBlock Text="Display" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavPaths"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Paths">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Folder}" />
                        <TextBlock Text="Paths" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavSchema"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Schema">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.FileCode}" />
                        <TextBlock Text="Schema Export" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavTheme"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Theme">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Palette}" />
                        <TextBlock Text="Theme" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavAbout"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="About">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Info}" />
                        <TextBlock Text="About" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Right content -->
        <ScrollViewer Grid.Column="1" Padding="20,16,20,0">
            <StackPanel Spacing="16" Margin="0,0,0,24">

                <!-- Display section -->
                <StackPanel Name="SectionDisplay" Spacing="12">
                    <TextBlock Text="Display" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Resolve Item Names" FontWeight="SemiBold" />
                                <TextBlock Text="Show UniqueName + EN display name for numeric param values."
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="Data fetched from ao-bin-dumps on first launch, cached 7 days."
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ResolveItemNames}"
                                         IsEnabled="{Binding GameDataLoaded}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Close button hides to system tray" FontWeight="SemiBold" />
                                <TextBlock Text="Clicking X hides the window instead of closing. Use tray icon to show or exit."
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding MinimizeToTray}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Resolve Item Icons" FontWeight="SemiBold" />
                                <TextBlock Text="Show item icons in the Packet Detail panel."
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="Fetched from render.albiononline.com, cached permanently to disk."
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ResolveIcons}"
                                         IsEnabled="{Binding GameDataLoaded}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Force Expand All Rows" FontWeight="SemiBold" />
                                <TextBlock Text="Automatically expand all Packet Detail rows to show full decoded values."
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="Arrays and dicts shown one entry per line with item index resolution."
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ForceExpandRows}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Auto-start capture on launch" FontWeight="SemiBold" />
                                <TextBlock Text="Start network capture automatically when the app opens."
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="Uses the last selected device (or all adapters if set to Automatic)."
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding AutoStartCapture}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Auto-save capture log on exit" FontWeight="SemiBold" />
                                <TextBlock Text="Save all captured packets to a JSON file when closing the app."
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="Saved to AppData\AlbionPacketExplorer\logs\ with a timestamp filename."
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding AutoSaveLogs}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Paths section -->
                <StackPanel Name="SectionPaths" Spacing="12" IsVisible="False">
                    <TextBlock Text="Paths" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="App Data Folder" FontWeight="SemiBold" />
                            <TextBlock Text="Settings, layout and item cache are stored here."
                                       Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding DataFolderPath}"
                                       Foreground="Gray" FontSize="11" FontFamily="Consolas,Monospace"
                                       TextWrapping="Wrap" Opacity="0.8" />
                            <Button Classes="ghost" Command="{Binding OpenDataFolderCommand}" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                    <TextBlock Text="Open in Explorer" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="SAT Instances Folder" FontWeight="SemiBold" />
                            <TextBlock Text="packet_sniffer.json files are inside one of the instance subfolders."
                                       Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding SatPacketSnifferPath}"
                                       Foreground="Gray" FontSize="11" FontFamily="Consolas,Monospace"
                                       TextWrapping="Wrap" Opacity="0.8" />
                            <Button Classes="ghost" Command="{Binding OpenSatFolderCommand}" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                    <TextBlock Text="Open in Explorer" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Item Name Cache" FontWeight="SemiBold" />
                            <TextBlock Text="Fetched from ao-bin-dumps, refreshed every 7 days."
                                       Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding ItemCachePath}"
                                       Foreground="Gray" FontSize="11" FontFamily="Consolas,Monospace"
                                       TextWrapping="Wrap" Opacity="0.8" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Schema Export section -->
                <StackPanel Name="SectionSchema" Spacing="12" IsVisible="False">
                    <TextBlock Text="Schema Export" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Export merged param schema for an event/request as standalone JSON, ready for SAT PR submission."
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="Auto,8,120,8,Auto,8,*">
                                <TextBlock Grid.Column="0" Text="Kind:" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="2" SelectedItem="{Binding ExportKind}">
                                    <ComboBoxItem Content="EVENT" />
                                    <ComboBoxItem Content="REQUEST" />
                                    <ComboBoxItem Content="RESPONSE" />
                                </ComboBox>
                                <TextBlock Grid.Column="4" Text="Code:" VerticalAlignment="Center" />
                                <TextBox Grid.Column="6" Text="{Binding ExportCode}"
                                         PlaceholderText="e.g. 32" MaxLength="5" />
                            </Grid>

                            <TextBox Text="{Binding ExportPreview}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas,Monospace"
                                     FontSize="11"
                                     AcceptsReturn="True"
                                     Height="200"
                                     TextWrapping="NoWrap"
                                     PlaceholderText="Enter kind + code above to preview schema…" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="ghost" Command="{Binding CopyExportCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Copy}" />
                                        <TextBlock Text="Copy to Clipboard" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding SaveExportCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Save}" />
                                        <TextBlock Text="Save as JSON" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Theme section -->
                <StackPanel Name="SectionTheme" Spacing="12" IsVisible="False">
                    <TextBlock Text="Theme" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="Dark Mode" FontWeight="SemiBold" />
                                <TextBlock Text="Switch between dark and light base theme."
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding IsDarkMode}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Color Theme" FontWeight="SemiBold" />
                            <TextBlock Text="Pick a color accent for the UI."
                                       Foreground="Gray" FontSize="12" />
                            <ListBox ItemsSource="{Binding AvailableThemes}"
                                     SelectedItem="{Binding SelectedTheme}"
                                     SelectionMode="Single">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="36" CornerRadius="6" Margin="4"
                                                Background="{Binding AccentBrush}">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- About section -->
                <StackPanel Name="SectionAbout" Spacing="12" IsVisible="False">
                    <TextBlock Text="About" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Albion Packet Explorer" FontWeight="Bold" FontSize="15" />
                            <TextBlock Text="{Binding Version}" Foreground="Gray" FontSize="12" />
                            <TextBlock Text="Reads packet_sniffer.json from AlbionOnline-StatisticsAnalysis and decodes raw Albion Online network packets. Useful for exploring every field of every packet to write better event constructors in SAT."
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</controls:ApxWindow>
