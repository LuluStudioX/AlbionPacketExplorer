<controls:ApxWindow xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
                xmlns:vm="using:AlbionPacketExplorer.ViewModels"
                xmlns:loc="using:AlbionPacketExplorer.Markup"
                x:Class="AlbionPacketExplorer.Views.SettingsWindow"
                x:DataType="vm:SettingsViewModel"
                Title="{loc:T settings.title}"
                Icon="/Assets/app-icon.ico"
                Width="800" Height="640"
                MinWidth="640" MinHeight="420"
                MaxHeight="820"
                CanResize="True"
                WindowStartupLocation="CenterOwner">

    <Grid ColumnDefinitions="180,*">

        <!-- Left nav -->
        <Border Grid.Column="0" Background="{DynamicResource Apx.Surface}" Padding="0,8"
                BorderBrush="{DynamicResource Apx.Border}" BorderThickness="0,0,1,0">
            <StackPanel Spacing="2">
                <Button Name="NavDisplay"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Display">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Monitor}" />
                        <TextBlock Text="{loc:T settings.nav.display}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavPaths"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Paths">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Folder}" />
                        <TextBlock Text="{loc:T settings.nav.paths}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavSchema"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Schema">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.FileCode}" />
                        <TextBlock Text="{loc:T settings.nav.schema}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavTheme"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="Theme">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Palette}" />
                        <TextBlock Text="{loc:T settings.nav.theme}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Name="NavAbout"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        Click="OnNavClicked"
                        Tag="About">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Info}" />
                        <TextBlock Text="{loc:T settings.nav.about}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Right content -->
        <ScrollViewer Grid.Column="1" Padding="24,20,16,0">
            <StackPanel Spacing="16" Margin="0,0,8,24">

                <!-- Display section -->
                <StackPanel Name="SectionDisplay" Spacing="12">
                    <TextBlock Text="{loc:T settings.nav.display}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.resolveNames}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.resolveNames.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.resolveNames.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ResolveItemNames}"
                                         IsEnabled="{Binding GameDataLoaded}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.density}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.density.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DensityOptions}"
                                      SelectedItem="{Binding Density}"
                                      MinWidth="140"
                                      VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.tray}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.tray.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding MinimizeToTray}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.resolveIcons}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.resolveIcons.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.resolveIcons.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ResolveIcons}"
                                         IsEnabled="{Binding GameDataLoaded}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.forceExpand}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.forceExpand.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.forceExpand.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding ForceExpandRows}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.autoStart}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.autoStart.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.autoStart.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding AutoStartCapture}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.display.autoSave}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.display.autoSave.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{loc:T settings.display.autoSave.note}"
                                           Foreground="Gray" FontSize="11" TextWrapping="Wrap" Opacity="0.6" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding AutoSaveLogs}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Paths section -->
                <StackPanel Name="SectionPaths" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.paths}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.paths.appData}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.paths.appData.desc}"
                                       Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding DataFolderPath}"
                                       Foreground="Gray" FontSize="11" FontFamily="Consolas,Monospace"
                                       TextWrapping="Wrap" Opacity="0.8" />
                            <Button Classes="ghost" Command="{Binding OpenDataFolderCommand}" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                    <TextBlock Text="{loc:T settings.paths.openInExplorer}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.paths.logFolder}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.paths.logFolder.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SatPacketSnifferPath}"
                                       Foreground="Gray" FontSize="11" FontFamily="Consolas,Monospace"
                                       TextWrapping="Wrap" Opacity="0.8" />
                            <Button Classes="ghost" Command="{Binding OpenSatFolderCommand}" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                    <TextBlock Text="{loc:T settings.paths.openInExplorer}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.paths.itemCache}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.paths.itemCache.desc}"
                                       Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding ItemCachePath}"
                                       Foreground="Gray" FontSize="11" FontFamily="Consolas,Monospace"
                                       TextWrapping="Wrap" Opacity="0.8" />
                            <Button Classes="ghost" Command="{Binding OpenItemCacheFolderCommand}" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                                    <TextBlock Text="{loc:T settings.paths.openInExplorer}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Schema Export section -->
                <StackPanel Name="SectionSchema" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.schema}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{loc:T settings.schema.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="Auto,8,120,8,Auto,8,*">
                                <TextBlock Grid.Column="0" Text="{loc:T settings.schema.kind}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="2" SelectedItem="{Binding ExportKind}">
                                    <ComboBoxItem Content="EVENT" />
                                    <ComboBoxItem Content="REQUEST" />
                                    <ComboBoxItem Content="RESPONSE" />
                                </ComboBox>
                                <TextBlock Grid.Column="4" Text="{loc:T settings.schema.code}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="6" Text="{Binding ExportCode}"
                                         PlaceholderText="{loc:T settings.schema.code.placeholder}" MaxLength="5" />
                            </Grid>

                            <TextBox Text="{Binding ExportPreview}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas,Monospace"
                                     FontSize="11"
                                     AcceptsReturn="True"
                                     Height="200"
                                     TextWrapping="NoWrap"
                                     PlaceholderText="{loc:T settings.schema.preview.placeholder}" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="ghost" Command="{Binding CopyExportCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Copy}" />
                                        <TextBlock Text="{loc:T settings.schema.copy}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding SaveExportCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Path Classes="icon sm" Data="{StaticResource Icon.Save}" />
                                        <TextBlock Text="{loc:T settings.schema.save}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Theme section -->
                <StackPanel Name="SectionTheme" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.theme}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{loc:T settings.theme.dark}" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:T settings.theme.dark.desc}"
                                           Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding IsDarkMode}"
                                         VerticalAlignment="Center" Margin="20,0,0,0" />
                        </Grid>
                    </Border>

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{loc:T settings.theme.color}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:T settings.theme.color.desc}"
                                       Foreground="Gray" FontSize="12" />
                            <ListBox ItemsSource="{Binding AvailableThemes}"
                                     SelectedItem="{Binding SelectedTheme}"
                                     SelectionMode="Single">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="36" CornerRadius="6" Margin="4"
                                                Background="{Binding AccentBrush}">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- About section -->
                <StackPanel Name="SectionAbout" Spacing="12" IsVisible="False">
                    <TextBlock Text="{loc:T settings.nav.about}" FontSize="18" FontWeight="SemiBold" />

                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:T settings.about.name}" FontWeight="Bold" FontSize="15" />
                            <TextBlock Text="{Binding Version}" Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{loc:T settings.about.desc}"
                                       Foreground="Gray" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</controls:ApxWindow>
