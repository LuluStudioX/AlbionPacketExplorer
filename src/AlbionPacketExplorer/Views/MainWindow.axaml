<controls:ApxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
        xmlns:vm="using:AlbionPacketExplorer.ViewModels"
        xmlns:views="using:AlbionPacketExplorer.Views"
        xmlns:loc="using:AlbionPacketExplorer.Markup"
        x:Class="AlbionPacketExplorer.Views.MainWindow"
        Title="{loc:T app.title}"
        Icon="/Assets/app-icon.ico"
        Width="1400" Height="900"
        MinWidth="560" MinHeight="420"
        x:DataType="vm:MainViewModel"
        KeyDown="OnKeyDown">

    <Panel>
    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Background="{DynamicResource Apx.Surface}" ZIndex="1"
                   LastChildFill="True">

        <!-- Status text + loading spinner — docked right; declared first so the action
             WrapPanel (last child) fills the remaining width and wraps when narrow. -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0"
                    MaxWidth="320">
            <!-- Update available banner -->
            <StackPanel Orientation="Horizontal" Spacing="6"
                        IsVisible="{Binding UpdateVersion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource Apx.Accent}"
                           Text="{Binding UpdateVersion, StringFormat='v{0} available'}" />
                <Button Classes="ghost" Command="{Binding ApplyUpdateCommand}"
                        Padding="8,4" IsEnabled="{Binding IsUpdating, Converter={x:Static BoolConverters.Not}}"
                        ToolTip.Tip="Download and install update, then restart">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <controls:ApxSpinner Width="12" Height="12" IsVisible="{Binding IsUpdating}" />
                        <TextBlock Text="Update" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <controls:ApxSpinner Width="16" Height="16" IsVisible="{Binding IsLoading}" />
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center" FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding StatusText}"
                       Foreground="{DynamicResource Apx.Text}" />
        </StackPanel>

        <!-- Action controls — fill the remaining width and wrap to multiple rows when narrow -->
        <WrapPanel Orientation="Horizontal" Margin="6,4" VerticalAlignment="Center">
            <ComboBox ItemsSource="{Binding AvailableDevices}"
                      SelectedItem="{Binding SelectedDevice}"
                      DisplayMemberBinding="{Binding DisplayName}"
                      MinWidth="160" MaxWidth="480" MaxDropDownHeight="450" Margin="0,0,4,0"
                      IsEnabled="{Binding IsCapturing, Converter={x:Static BoolConverters.Not}}">
                <ToolTip.Tip>Select network adapter to capture Albion traffic from.</ToolTip.Tip>
            </ComboBox>

            <Button Classes="iconbtn" Command="{Binding RefreshDevicesCommand}" Margin="0,0,4,0">
                <ToolTip.Tip>Re-scan network adapters.</ToolTip.Tip>
                <Path Classes="icon" Data="{StaticResource Icon.Refresh}" />
            </Button>

            <Button Classes="success" Command="{Binding StartCaptureCommand}" Padding="10,8" Margin="0,0,4,0">
                <ToolTip.Tip>Start live packet capture. Npcap must be installed. Run as Administrator if capture fails.</ToolTip.Tip>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="icon sm" Data="{StaticResource Icon.Play}" Stroke="#FFFFFF" />
                    <TextBlock Text="Capture" VerticalAlignment="Center" Foreground="#FFFFFF" />
                </StackPanel>
            </Button>

            <Button Classes="danger" Command="{Binding StopCaptureCommand}" Padding="10,8" Margin="0,0,4,0">
                <ToolTip.Tip>Stop live capture. All captured packets remain visible.</ToolTip.Tip>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="icon sm" Data="{StaticResource Icon.Stop}" Stroke="#FFFFFF" />
                    <TextBlock Text="Stop" VerticalAlignment="Center" Foreground="#FFFFFF" />
                </StackPanel>
            </Button>

            <Separator Width="1" Background="{DynamicResource Apx.Border}" Margin="4,0" />

            <Button Classes="iconbtn" Name="SettingsButton" Click="OnSettingsClicked" Margin="0,0,4,0">
                <ToolTip.Tip>Open settings.</ToolTip.Tip>
                <Path Classes="icon" Data="{StaticResource Icon.Settings}" />
            </Button>

            <Button Classes="iconbtn" Command="{Binding ToggleFocusModeCommand}" Margin="0,0,4,0">
                <ToolTip.Tip>Switch between side-by-side and stacked layout. (F5)</ToolTip.Tip>
                <Path Classes="icon" Data="{StaticResource Icon.Layers}" />
            </Button>

            <Button Classes="iconbtn" Click="OnResetLayoutClicked" Margin="0,0,4,0">
                <ToolTip.Tip>Reset panel sizes to default.</ToolTip.Tip>
                <Path Classes="icon" Data="{StaticResource Icon.Refresh}" />
            </Button>

            <Separator Width="1" Background="{DynamicResource Apx.Border}" Margin="4,0" />

            <Button Classes="ghost" Command="{Binding SaveFileCommand}" Padding="10,8" Margin="0,0,4,0">
                <ToolTip.Tip>Save all loaded/captured packets to a newline-delimited JSON file.</ToolTip.Tip>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="icon sm" Data="{StaticResource Icon.Save}" />
                    <TextBlock Text="Save JSON" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Classes="ghost" Command="{Binding OpenFileCommand}" Padding="10,8">
                <ToolTip.Tip>Load a saved packet capture (newline-delimited JSON).</ToolTip.Tip>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                    <TextBlock Text="Open JSON" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </WrapPanel>
        </DockPanel>

        <!-- content area: only one of the two grids visible at a time -->
        <Panel Grid.Row="1" ClipToBounds="True">

        <!-- ═══════════════════════════════════════
             OVERVIEW MODE (side-by-side, default)
             ═══════════════════════════════════════ -->
        <Grid x:Name="OverviewGrid"
              RowDefinitions="200,2,*"
              ClipToBounds="True"
              IsVisible="{Binding FocusMode, Converter={x:Static BoolConverters.Not}}">

            <DockPanel Grid.Row="0" ClipToBounds="True">
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource Apx.Card}"
                        BorderBrush="{DynamicResource Apx.Accent}"
                        BorderThickness="0,0,0,2"
                        Padding="6,3">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{loc:T panel.eventSummary}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Apx.Text}" />
                        <Border Background="{DynamicResource Apx.Highlight}"
                                CornerRadius="8" Padding="4,1"
                                ToolTip.Tip="Each row = one packet type (e.g. EVENT 32).&#xA;Count = how many times seen.&#xA;Keys = which param indices were present, with % showing how often.&#xA;100% = always present (required field). Less = optional/conditional.&#xA;&#xA;Click a row to filter the packet list below.">
                            <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                        </Border>
                    </StackPanel>
                </Border>
                <views:CodeAggregatorView x:Name="OverviewAggregatorView" DataContext="{Binding Aggregator}" />
            </DockPanel>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <Grid Grid.Row="2" x:Name="BottomGrid" ColumnDefinitions="2*,2,*">
                <DockPanel Grid.Column="0" MinWidth="180" ClipToBounds="True">
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource Apx.Card}"
                            BorderBrush="{DynamicResource Apx.Highlight}"
                            BorderThickness="0,0,0,2"
                            Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{loc:T panel.packetList}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Apx.Text}" />
                            <Border Background="{DynamicResource Apx.Highlight}"
                                    CornerRadius="8" Padding="4,1"
                                    ToolTip.Tip="All individual packets matching the current filter.&#xA;Filter is set automatically when you click a row in Event Summary.&#xA;Click a packet row to inspect its fields in the detail panel.">
                                <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <views:PacketListView x:Name="OverviewPacketListView" DataContext="{Binding PacketList}" />
                </DockPanel>

                <GridSplitter Grid.Column="1" ResizeDirection="Columns"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <DockPanel Grid.Column="2" MinWidth="180" ClipToBounds="True">
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource Apx.Card}"
                            BorderBrush="{DynamicResource Apx.Danger}"
                            BorderThickness="0,0,0,2"
                            Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{loc:T panel.packetDetail}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Apx.Text}" />
                            <Border Background="{DynamicResource Apx.Highlight}"
                                    CornerRadius="8" Padding="4,1"
                                    ToolTip.Tip="Key/Type/Value breakdown of the selected packet.&#xA;Key = param index (0–255). Type = wire type. Value = decoded value.&#xA;Right-click a row to edit param name/note.">
                                <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <views:PacketDetailView x:Name="OverviewPacketDetailView" DataContext="{Binding PacketDetail}" />
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════
             FOCUS MODE (stacked, full-width detail)
             ═══════════════════════════════════════ -->
        <Grid x:Name="FocusGrid"
              RowDefinitions="160,2,*,2,*"
              IsVisible="{Binding FocusMode}">

            <Grid Grid.Row="0" RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{DynamicResource Apx.Card}"
                        BorderBrush="{DynamicResource Apx.Accent}"
                        BorderThickness="0,0,0,2"
                        Padding="6,3"
                        Cursor="Hand" PointerPressed="OnSummaryHeaderPressed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="SummaryCollapseIcon" Text="▼" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Apx.Accent}" />
                        <TextBlock Text="{loc:T panel.eventSummary}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Apx.Text}" />
                    </StackPanel>
                </Border>
                <views:CodeAggregatorView x:Name="FocusSummaryContent"
                                          Grid.Row="1"
                                          DataContext="{Binding Aggregator}" />
            </Grid>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <DockPanel Grid.Row="2">
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource Apx.Card}"
                        BorderBrush="{DynamicResource Apx.Highlight}"
                        BorderThickness="0,0,0,2"
                        Padding="6,3">
                    <TextBlock Text="Packet List"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Apx.Text}" />
                </Border>
                <views:PacketListView DataContext="{Binding PacketList}" />
            </DockPanel>

            <GridSplitter Grid.Row="3" ResizeDirection="Rows"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <DockPanel Grid.Row="4">
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource Apx.Card}"
                        BorderBrush="{DynamicResource Apx.Danger}"
                        BorderThickness="0,0,0,2"
                        Padding="6,3">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Packet Detail"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Apx.Text}" />
                        <Border Background="{DynamicResource Apx.Highlight}"
                                CornerRadius="8" Padding="4,1"
                                ToolTip.Tip="Right-click a row to edit param name/note.">
                            <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                        </Border>
                    </StackPanel>
                </Border>
                <views:PacketDetailView DataContext="{Binding PacketDetail}" />
            </DockPanel>

        </Grid>

        </Panel>

    </Grid>

    <!-- Toast overlay -->
    <controls:ApxToastHost Manager="{Binding ToastManager}"
                           IsHitTestVisible="False"
                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Panel>

</controls:ApxWindow>
