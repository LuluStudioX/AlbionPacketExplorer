<suki:SukiWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
        xmlns:vm="using:AlbionPacketExplorer.ViewModels"
        xmlns:views="using:AlbionPacketExplorer.Views"
        x:Class="AlbionPacketExplorer.Views.MainWindow"
        Title="Albion Packet Explorer"
        Icon="/Assets/app-icon.ico"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        x:DataType="vm:MainViewModel"
        KeyDown="OnKeyDown">

    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="6,4">
            <TextBlock VerticalAlignment="Center" Text="Device:" />
            <ComboBox ItemsSource="{Binding AvailableDevices}"
                      SelectedItem="{Binding SelectedDevice}"
                      DisplayMemberBinding="{Binding DisplayName}"
                      Width="260"
                      IsEnabled="{Binding IsCapturing, Converter={x:Static BoolConverters.Not}}">
                <ToolTip.Tip>Select which network adapter to capture Albion traffic from.</ToolTip.Tip>
            </ComboBox>
            <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}">
                <ToolTip.Tip>Re-scan network adapters.</ToolTip.Tip>
            </Button>
            <Button Content="▶ Start Capture"
                    Command="{Binding StartCaptureCommand}"
                    Background="#2a7a2a" Foreground="White">
                <ToolTip.Tip>Start live packet capture. Npcap must be installed. Run as Administrator if capture fails.</ToolTip.Tip>
            </Button>
            <Button Content="■ Stop Capture"
                    Command="{Binding StopCaptureCommand}"
                    Background="#7a2a2a" Foreground="White">
                <ToolTip.Tip>Stop live capture. All captured packets remain visible.</ToolTip.Tip>
            </Button>
            <Separator Width="1" Background="Gray" Margin="4,0" />
            <Button Content="⚙ Settings" Name="SettingsButton" Click="OnSettingsClicked" />
            <Button Content="{Binding LayoutToggleIcon}"
                    Command="{Binding ToggleFocusModeCommand}"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontSize="21"
                    Padding="14,8"
                    MinHeight="{Binding $parent[StackPanel].Bounds.Height}">
                <ToolTip.Tip>Switch between side-by-side (⊞) and stacked (⊟) layout. (F5)</ToolTip.Tip>
            </Button>
            <Separator Width="1" Background="Gray" Margin="4,0" />
            <Button Content="Save JSON…" Command="{Binding SaveFileCommand}">
                <ToolTip.Tip>Save all loaded/captured packets to a newline-delimited JSON file.</ToolTip.Tip>
            </Button>
            <Button Content="Open JSON File…" Command="{Binding OpenFileCommand}">
                <ToolTip.Tip>Load a packet_sniffer.json file recorded by SAT.&#xA;Default path: %LOCALAPPDATA%\StatisticsAnalysisTool\Instances\...\temp\packet_sniffer.json</ToolTip.Tip>
            </Button>
        </StackPanel>

        <!-- Status bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical">
            <ProgressBar Value="{Binding LoadProgress}" Maximum="1"
                         IsVisible="{Binding IsLoading}" Height="4" />
            <TextBlock Text="{Binding StatusText}" Margin="8,2" />
        </StackPanel>

        <!-- ═══════════════════════════════════════
             OVERVIEW MODE (side-by-side, default)
             ═══════════════════════════════════════ -->
        <Grid x:Name="OverviewGrid"
              RowDefinitions="200,4,*"
              IsVisible="{Binding FocusMode, Converter={x:Static BoolConverters.Not}}">

            <!-- TOP: Code Aggregator -->
            <DockPanel Grid.Row="0" MinHeight="80">
                <Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="6,3">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Event Summary" FontWeight="Bold" VerticalAlignment="Center" />
                        <Border Background="#333355" CornerRadius="8" Padding="4,1"
                                ToolTip.Tip="Each row = one packet type (e.g. EVENT 32).&#xA;Count = how many times seen.&#xA;Keys = which param indices were present, with % showing how often.&#xA;100% = always present (required field). Less = optional/conditional.&#xA;&#xA;Click a row to filter the packet list below.">
                            <TextBlock Text="?" FontSize="11" Foreground="#aaaaff" />
                        </Border>
                    </StackPanel>
                </Border>
                <views:CodeAggregatorView DataContext="{Binding Aggregator}" />
            </DockPanel>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows"
                          Background="#444444"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- BOTTOM: Packet List + Detail side by side -->
            <Grid Grid.Row="2" x:Name="BottomGrid" ColumnDefinitions="2*,4,*">
                <DockPanel Grid.Column="0" MinWidth="200">
                    <Border DockPanel.Dock="Top" Background="#1a2e1a" Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Packet List" FontWeight="Bold" VerticalAlignment="Center" />
                            <Border Background="#335533" CornerRadius="8" Padding="4,1"
                                    ToolTip.Tip="All individual packets matching the current filter.&#xA;Filter is set automatically when you click a row in Event Summary.&#xA;Click a packet row to inspect its fields in the detail panel.">
                                <TextBlock Text="?" FontSize="11" Foreground="#aaffaa" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <views:PacketListView DataContext="{Binding PacketList}" />
                </DockPanel>

                <GridSplitter Grid.Column="1" ResizeDirection="Columns"
                              Background="#444444"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <DockPanel Grid.Column="2" MinWidth="200">
                    <Border DockPanel.Dock="Top" Background="#2e1a1a" Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Packet Detail" FontWeight="Bold" VerticalAlignment="Center" />
                            <Border Background="#553333" CornerRadius="8" Padding="4,1"
                                    ToolTip.Tip="Key/Type/Value breakdown of the selected packet.&#xA;Key = param index (0–255). Type = wire type. Value = decoded value.&#xA;Right-click a row to edit param name/note.">
                                <TextBlock Text="?" FontSize="11" Foreground="#ffaaaa" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <views:PacketDetailView DataContext="{Binding PacketDetail}" />
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════
             FOCUS MODE (stacked, full-width detail)
             ═══════════════════════════════════════ -->
        <Grid x:Name="FocusGrid"
              RowDefinitions="160,4,*,4,*"
              IsVisible="{Binding FocusMode}">

            <!-- Row 0: Event Summary (collapsible) -->
            <DockPanel Grid.Row="0">
                <Border DockPanel.Dock="Top" Background="#1a1a2e" Padding="6,3"
                        Cursor="Hand" PointerPressed="OnSummaryHeaderPressed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="SummaryCollapseIcon" Text="▼" FontSize="10" VerticalAlignment="Center" Foreground="#aaaaff" />
                        <TextBlock Text="Event Summary" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <views:CodeAggregatorView x:Name="FocusSummaryContent"
                                          DataContext="{Binding Aggregator}" />
            </DockPanel>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows"
                          Background="#444444"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- Row 2: Packet List full-width -->
            <DockPanel Grid.Row="2">
                <Border DockPanel.Dock="Top" Background="#1a2e1a" Padding="6,3">
                    <TextBlock Text="Packet List" FontWeight="Bold" VerticalAlignment="Center" />
                </Border>
                <views:PacketListView DataContext="{Binding PacketList}" />
            </DockPanel>

            <GridSplitter Grid.Row="3" ResizeDirection="Rows"
                          Background="#444444"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- Row 4: Packet Detail full-width -->
            <DockPanel Grid.Row="4">
                <Border DockPanel.Dock="Top" Background="#2e1a1a" Padding="6,3">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Packet Detail" FontWeight="Bold" VerticalAlignment="Center" />
                        <Border Background="#553333" CornerRadius="8" Padding="4,1"
                                ToolTip.Tip="Right-click a row to edit param name/note.">
                            <TextBlock Text="?" FontSize="11" Foreground="#ffaaaa" />
                        </Border>
                    </StackPanel>
                </Border>
                <views:PacketDetailView DataContext="{Binding PacketDetail}" />
            </DockPanel>

        </Grid>

    </DockPanel>

</suki:SukiWindow>
