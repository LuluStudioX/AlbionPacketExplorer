<controls:ApxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
        xmlns:vm="using:AlbionPacketExplorer.ViewModels"
        xmlns:views="using:AlbionPacketExplorer.Views"
        xmlns:loc="using:AlbionPacketExplorer.Markup"
        x:Class="AlbionPacketExplorer.Views.MainWindow"
        Title="{loc:T app.title}"
        Icon="/Assets/app-icon.ico"
        Width="1400" Height="900"
        MinWidth="560" MinHeight="420"
        x:DataType="vm:MainViewModel">

    <Panel>
    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ═══════════ TOOLBAR ═══════════ -->
        <DockPanel Grid.Row="0" Background="{DynamicResource Apx.Surface}" ZIndex="1"
                   LastChildFill="True">

            <!-- Status text + spinner — docked right; declared first so the action WrapPanel
                 (last child) fills the remaining width and wraps when narrow. -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0"
                        MaxWidth="320">
                <StackPanel Orientation="Horizontal" Spacing="6"
                            IsVisible="{Binding UpdateVersion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource Apx.Accent}"
                               Text="{Binding UpdateVersion, StringFormat='v{0} available'}" />
                    <Button Classes="ghost" Command="{Binding ApplyUpdateCommand}"
                            Padding="8,4" IsEnabled="{Binding IsUpdating, Converter={x:Static BoolConverters.Not}}"
                            ToolTip.Tip="{loc:T toolbar.update.tip}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <controls:ApxSpinner Width="12" Height="12" IsVisible="{Binding IsUpdating}" />
                            <TextBlock Text="{loc:T toolbar.update}" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <controls:ApxSpinner Width="16" Height="16" IsVisible="{Binding IsLoading}" />
            </StackPanel>

            <WrapPanel Orientation="Horizontal" Margin="6,4" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding AvailableDevices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberBinding="{Binding DisplayName}"
                          MinWidth="160" MaxWidth="480" MaxDropDownHeight="450" Margin="0,0,4,0"
                          IsEnabled="{Binding IsCapturing, Converter={x:Static BoolConverters.Not}}">
                    <ToolTip.Tip><TextBlock Text="{loc:T toolbar.device.tip}" /></ToolTip.Tip>
                </ComboBox>

                <Button Classes="iconbtn" Command="{Binding RefreshDevicesCommand}" Margin="0,0,4,0"
                        ToolTip.Tip="{loc:T toolbar.refresh.tip}">
                    <Path Classes="icon" Data="{StaticResource Icon.Refresh}" />
                </Button>

                <Button Classes="success" Command="{Binding StartCaptureCommand}" Padding="10,8" Margin="0,0,4,0"
                        ToolTip.Tip="{loc:T toolbar.capture.tip}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Play}" Stroke="#FFFFFF" />
                        <TextBlock Text="{loc:T toolbar.capture}" VerticalAlignment="Center" Foreground="#FFFFFF" />
                    </StackPanel>
                </Button>

                <Button Classes="accent" Command="{Binding TogglePauseCommand}" Padding="10,8" Margin="0,0,4,0"
                        IsVisible="{Binding IsCapturing}"
                        ToolTip.Tip="{Binding PauseTip}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Pause}" Stroke="#FFFFFF"
                              IsVisible="{Binding !IsPaused}" />
                        <Path Classes="icon sm" Data="{StaticResource Icon.Play}" Stroke="#FFFFFF"
                              IsVisible="{Binding IsPaused}" />
                        <TextBlock Text="{Binding PauseLabel}" VerticalAlignment="Center" Foreground="#FFFFFF" />
                    </StackPanel>
                </Button>

                <Button Classes="danger" Command="{Binding StopCaptureCommand}" Padding="10,8" Margin="0,0,4,0"
                        ToolTip.Tip="{loc:T toolbar.stop.tip}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Stop}" Stroke="#FFFFFF" />
                        <TextBlock Text="{loc:T toolbar.stop}" VerticalAlignment="Center" Foreground="#FFFFFF" />
                    </StackPanel>
                </Button>

                <Separator Width="1" Background="{DynamicResource Apx.Border}" Margin="4,0" />

                <Button Classes="iconbtn" Name="SettingsButton" Click="OnSettingsClicked" Margin="0,0,4,0"
                        ToolTip.Tip="{loc:T toolbar.settings.tip}">
                    <Path Classes="icon" Data="{StaticResource Icon.Settings}" />
                </Button>

                <Button Classes="iconbtn" Click="OnResetLayoutClicked" Margin="0,0,4,0"
                        ToolTip.Tip="{loc:T toolbar.resetLayout.tip}">
                    <Path Classes="icon" Data="{StaticResource Icon.Refresh}" />
                </Button>

                <Separator Width="1" Background="{DynamicResource Apx.Border}" Margin="4,0" />

                <!-- Save: dropdown of formats (JSON / CSV / RAW). -->
                <Button Classes="ghost" Padding="10,8" Margin="0,0,4,0"
                        IsEnabled="{Binding CanSaveAnything}"
                        ToolTip.Tip="{loc:T toolbar.save.tip}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Save}" />
                        <TextBlock Text="{loc:T toolbar.save}" VerticalAlignment="Center" />
                        <Path Classes="icon sm muted" Data="{StaticResource Icon.ChevronDown}" />
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="{loc:T toolbar.save.json}" Command="{Binding SaveFileCommand}" />
                            <MenuItem Header="{loc:T toolbar.save.csv}" Command="{Binding SaveCsvCommand}" />
                            <MenuItem Header="{loc:T toolbar.save.raw}" Command="{Binding SaveRawCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button Classes="ghost" Command="{Binding OpenFileCommand}" Padding="10,8"
                        ToolTip.Tip="{loc:T toolbar.open.tip}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource Icon.FolderOpen}" />
                        <TextBlock Text="{loc:T toolbar.open}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </DockPanel>

        <!-- ═══════════ FIRST-RUN WELCOME BANNER ═══════════ -->
        <Border Grid.Row="1" Background="{DynamicResource Apx.Card}"
                BorderBrush="{DynamicResource Apx.Accent}" BorderThickness="0,0,0,2"
                Padding="12,8" IsVisible="{Binding ShowWelcome}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Path Grid.Column="0" Classes="icon" Data="{StaticResource Icon.Info}"
                      Stroke="{DynamicResource Apx.Accent}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{loc:T welcome.title}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Apx.Text}" />
                    <TextBlock Text="{loc:T welcome.body}" FontSize="12"
                               Foreground="{DynamicResource Apx.TextMuted}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="10,0,0,0">
                    <ComboBox ItemsSource="{Binding AvailableCultures}"
                              SelectedItem="{Binding Culture}"
                              MinWidth="80" VerticalAlignment="Center"
                              ToolTip.Tip="{loc:T settings.theme.language}" />
                    <Button Classes="ghost" Command="{Binding OpenGlossaryCommand}" Padding="10,6">
                        <TextBlock Text="{loc:T welcome.glossary}" />
                    </Button>
                    <Button Classes="accent" Command="{Binding DismissWelcomeCommand}" Padding="10,6">
                        <TextBlock Text="{loc:T welcome.dismiss}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ WORKSPACE: sidebar | table + detail ═══════════ -->
        <Grid Grid.Row="2" x:Name="WorkspaceGrid" ColumnDefinitions="260,2,*" ClipToBounds="True">

            <!-- FILTER SIDEBAR -->
            <Grid Grid.Column="0" x:Name="SidebarPanel" RowDefinitions="Auto,*"
                  Background="{DynamicResource Apx.Surface}" ClipToBounds="True">

                <!-- Status group -->
                <controls:DetachableHost x:Name="StatusHost" Grid.Row="0" Title="{loc:T sidebar.status}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="{DynamicResource Apx.Card}"
                                BorderBrush="{DynamicResource Apx.Accent}" BorderThickness="0,0,0,2" Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{loc:T sidebar.status}" FontWeight="Bold"
                                           VerticalAlignment="Center" Foreground="{DynamicResource Apx.Text}" />
                                <Border Background="{DynamicResource Apx.Highlight}" CornerRadius="8" Padding="4,1"
                                        ToolTip.Tip="{loc:T sidebar.status.help}">
                                    <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <views:StatusFilterView Margin="6,6,6,10" DataContext="{Binding PacketList}" />
                    </DockPanel>
                </controls:DetachableHost>

                <!-- By-code group -->
                <controls:DetachableHost x:Name="ByCodeHost" Grid.Row="1" Title="{loc:T sidebar.byCode}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="{DynamicResource Apx.Card}"
                                BorderBrush="{DynamicResource Apx.Highlight}" BorderThickness="0,0,0,2" Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{loc:T sidebar.byCode}" FontWeight="Bold"
                                           Foreground="{DynamicResource Apx.Text}" />
                                <Border Background="{DynamicResource Apx.Highlight}" CornerRadius="8" Padding="4,1"
                                        ToolTip.Tip="{loc:T panel.eventSummary.help}">
                                    <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <Panel>
                            <views:CodeAggregatorView DataContext="{Binding Aggregator}" />
                            <Border Background="{DynamicResource Apx.Surface}" Padding="16"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding !PacketList.HasData}">
                                <TextBlock Text="{loc:T empty.byCode}"
                                           Foreground="{DynamicResource Apx.TextFaint}"
                                           FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Panel>
                    </DockPanel>
                </controls:DetachableHost>
            </Grid>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- TABLE + DETAIL -->
            <Grid Grid.Column="2" x:Name="ContentGrid" RowDefinitions="*,2,2*" ClipToBounds="True">
                <controls:DetachableHost x:Name="ListHost" Grid.Row="0" Title="{loc:T panel.packetList}">
                <DockPanel ClipToBounds="True">
                    <Border DockPanel.Dock="Top" Background="{DynamicResource Apx.Card}"
                            BorderBrush="{DynamicResource Apx.Highlight}" BorderThickness="0,0,0,2" Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Sidebar collapse / expand toggle -->
                            <Button Classes="iconbtn" Padding="2" Width="22" Height="22"
                                    Command="{Binding ToggleSidebarCommand}"
                                    ToolTip.Tip="{loc:T toolbar.toggleSidebar.tip}">
                                <Panel>
                                    <Path Classes="icon sm" Data="{StaticResource Icon.ChevronLeft}"
                                          IsVisible="{Binding SidebarVisible}" />
                                    <Path Classes="icon sm" Data="{StaticResource Icon.ChevronRight}"
                                          IsVisible="{Binding !SidebarVisible}" />
                                </Panel>
                            </Button>
                            <TextBlock Text="{loc:T panel.packetList}" FontWeight="Bold"
                                       VerticalAlignment="Center" Foreground="{DynamicResource Apx.Text}" />
                            <Border Background="{DynamicResource Apx.Highlight}" CornerRadius="8" Padding="4,1"
                                    ToolTip.Tip="{loc:T panel.packetList.help}">
                                <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Panel>
                        <views:PacketListView x:Name="PacketListViewHost" DataContext="{Binding PacketList}" />
                        <controls:EmptyState Icon="{StaticResource Icon.Radio}"
                                             Title="{loc:T empty.noData.title}"
                                             Message="{loc:T empty.noData.message}"
                                             IsHitTestVisible="False"
                                             IsVisible="{Binding !PacketList.HasData}" />
                    </Panel>
                </DockPanel>
                </controls:DetachableHost>

                <GridSplitter x:Name="ContentSplitter" Grid.Row="1" ResizeDirection="Rows"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <controls:DetachableHost x:Name="DetailHost" Grid.Row="2" Title="{loc:T panel.packetDetail}">
                <DockPanel ClipToBounds="True">
                    <Border DockPanel.Dock="Top" Background="{DynamicResource Apx.Card}"
                            BorderBrush="{DynamicResource Apx.Danger}" BorderThickness="0,0,0,2" Padding="6,3">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{loc:T panel.packetDetail}" FontWeight="Bold"
                                       VerticalAlignment="Center" Foreground="{DynamicResource Apx.Text}" />
                            <Border Background="{DynamicResource Apx.Highlight}" CornerRadius="8" Padding="4,1"
                                    ToolTip.Tip="{loc:T panel.packetDetail.help}">
                                <TextBlock Text="?" FontSize="11" Foreground="{DynamicResource Apx.Text}" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Panel>
                        <views:PacketDetailView x:Name="PacketDetailViewHost" DataContext="{Binding PacketDetail}" />
                        <controls:EmptyState Icon="{StaticResource Icon.Eye}"
                                             Title="{loc:T empty.noSelection.title}"
                                             Message="{loc:T empty.noSelection.message}"
                                             IsHitTestVisible="False"
                                             IsVisible="{Binding !PacketDetail.HasPacket}" />
                    </Panel>
                </DockPanel>
                </controls:DetachableHost>
            </Grid>
        </Grid>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="3" Background="{DynamicResource Apx.Surface}"
                BorderBrush="{DynamicResource Apx.Border}" BorderThickness="0,1,0,0" Padding="10,3">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{DynamicResource Apx.Success}" IsVisible="{Binding IsCapturing}" />
                    <TextBlock Text="{Binding PacketList.CountText}" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource Apx.TextMuted}" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding StatusText}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{DynamicResource Apx.TextMuted}"
                           TextTrimming="CharacterEllipsis" MaxWidth="500" />
            </Grid>
        </Border>

    </Grid>

    <!-- Toast overlay -->
    <controls:ApxToastHost Manager="{Binding ToastManager}"
                           IsHitTestVisible="False"
                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Panel>

</controls:ApxWindow>
