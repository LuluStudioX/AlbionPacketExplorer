<controls:ApxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
        xmlns:vm="using:AlbionPacketExplorer.ViewModels"
        xmlns:loc="using:AlbionPacketExplorer.Markup"
        x:Class="AlbionPacketExplorer.Views.EnumLabelWindow"
        x:DataType="vm:EnumLabelViewModel"
        Icon="/Assets/app-icon.ico"
        Title="{Binding Title}"
        Width="380" Height="220"
        MinWidth="300" MinHeight="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="14">

        <StackPanel Spacing="4">
            <TextBlock Text="{loc:T enumLabel.value}" FontSize="12" Foreground="Gray" />
            <TextBlock Text="{Binding ValueText}" FontFamily="Consolas,Monospace"
                       Foreground="{DynamicResource Apx.Text}" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="{loc:T enumLabel.label}" FontSize="12" Foreground="Gray" />
            <TextBox Text="{Binding Label}"
                     PlaceholderText="{loc:T enumLabel.label.placeholder}"
                     MaxLength="64" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Classes="ghost" Content="{loc:T enumLabel.clear}" Command="{Binding ClearCommand}" />
            <Button Classes="success" Content="{loc:T enumLabel.save}" Command="{Binding SaveCommand}" />
        </StackPanel>

    </StackPanel>
</controls:ApxWindow>
