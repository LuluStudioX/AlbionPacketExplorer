<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AlbionPacketExplorer.ViewModels"
             xmlns:views="using:AlbionPacketExplorer.Views"
             x:Class="AlbionPacketExplorer.Views.PacketDetailView"
             x:DataType="vm:PacketDetailViewModel">

    <DockPanel>

        <!-- Hide preset toolbar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="4,2,4,4">
            <TextBox Text="{Binding NewHidePresetName}" Width="130" PlaceholderText="Hide preset name…" FontSize="11" />
            <Button Classes="iconbtn" Command="{Binding SaveHidePresetCommand}" Padding="6" ToolTip.Tip="Save current hidden rows as preset">
                <Path Classes="icon sm" Data="{StaticResource Icon.Check}" />
            </Button>
            <ComboBox ItemsSource="{Binding HidePresets}"
                      SelectedItem="{Binding SelectedHidePreset, Mode=TwoWay}"
                      DisplayMemberBinding="{Binding Name}"
                      PlaceholderText="Load hide preset…"
                      MinWidth="140" FontSize="11" />
            <Button Classes="iconbtn" Command="{Binding LoadHidePresetCommand}" Padding="6" ToolTip.Tip="Apply selected hide preset">
                <Path Classes="icon sm" Data="{StaticResource Icon.ChevronRight}" />
            </Button>
            <Button Classes="iconbtn" Command="{Binding DeleteHidePresetCommand}" Padding="6" ToolTip.Tip="Delete selected hide preset">
                <Path Classes="icon sm" Data="{StaticResource Icon.Trash}" />
            </Button>
            <Button Classes="ghost" Command="{Binding UnhideAllRowsCommand}" Padding="8,4" ToolTip.Tip="Show all hidden rows">
                <TextBlock Text="Show all" FontSize="11" />
            </Button>
        </StackPanel>

    <DataGrid x:Name="MainGrid" ItemsSource="{Binding Rows}"
              SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserSortColumns="True"
              CanUserResizeColumns="True"
              FontSize="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}"
              RowHeight="{Binding $parent[Window].((vm:MainViewModel)DataContext).RowHeight, FallbackValue=26}"
              HorizontalScrollBarVisibility="Disabled"
              GridLinesVisibility="Horizontal">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Value"    Command="{Binding CopyValueCommand}" />
                    <MenuItem Header="View Full Value…" Command="{Binding ViewFullValueCommand}" />
                    <MenuItem Header="Copy Row"      Command="{Binding CopyRowCommand}" />
                    <Separator />
                    <MenuItem Header="Copy All Rows" Command="{Binding CopyAllRowsCommand}" />
                    <Separator />
                    <MenuItem Header="Preview Resolve" Command="{Binding PreviewResolveCommand}" />
                    <Separator />
                    <MenuItem Header="Edit Param Name…" Command="{Binding EditParamCommand}" />
                    <Separator />
                    <MenuItem Header="Hide Row"         Command="{Binding HideRowCommand}" />
                    <MenuItem Header="Unhide Row"       Command="{Binding UnhideRowCommand}" />
                    <MenuItem Header="Show All Rows"    Command="{Binding UnhideAllRowsCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>

                <DataGridTemplateColumn Width="160" SortMemberPath="Key" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Key" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterKey, Mode=TwoWay}"
                                                 PlaceholderText="Filter Key…" Width="180" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ParamRow">
                            <Panel VerticalAlignment="Center">
                                <!-- Normal view -->
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            Margin="4,0"
                                            ToolTip.Tip="{Binding Note}"
                                            IsVisible="{Binding IsVisible}">
                                    <TextBlock Text="{Binding Key}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SchemaName}"
                                               Foreground="#aaaacc" FontSize="13"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding SchemaName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                             Fill="{DynamicResource Apx.TextFaint}"
                                             ToolTip.Tip="SAT-derived (base schema)">
                                        <Ellipse.IsVisible>
                                            <Binding Path="Source" Converter="{x:Static views:ParamSourceConverters.IsBase}" />
                                        </Ellipse.IsVisible>
                                    </Ellipse>
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                             Fill="{DynamicResource ThemeAccentBrush}"
                                             ToolTip.Tip="Your custom override (user schema)">
                                        <Ellipse.IsVisible>
                                            <Binding Path="Source" Converter="{x:Static views:ParamSourceConverters.IsUser}" />
                                        </Ellipse.IsVisible>
                                    </Ellipse>
                                </StackPanel>
                                <!-- Hidden / collapsed view -->
                                <TextBlock Text="{Binding Key}" FontSize="10"
                                           FontStyle="Italic" Margin="4,0"
                                           Foreground="{DynamicResource Apx.TextFaint}"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsHidden}" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="100" SortMemberPath="Type" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Type" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterType, Mode=TwoWay}"
                                                 PlaceholderText="Filter Type…" Width="160" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ParamRow">
                            <TextBlock Text="{Binding Type}" Margin="12,0" VerticalAlignment="Center"
                                       IsVisible="{Binding IsVisible}"
                                       Foreground="{DynamicResource Apx.Text}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="1.2*" MinWidth="80" SortMemberPath="Value" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Value" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterValue, Mode=TwoWay}"
                                                 PlaceholderText="Filter Value…" Width="200" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ParamRow">
                            <Panel VerticalAlignment="Center">
                                <!-- Normal: collections show a chevron to expand inline;
                                     the value text collapses to "[N items]" until expanded. -->
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="8,4"
                                            IsVisible="{Binding IsVisible}">
                                    <Button Classes="iconbtn" Padding="2" Width="20" Height="20"
                                            VerticalAlignment="Top"
                                            Command="{Binding $parent[UserControl].DataContext.ToggleRowExpandCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding IsCollection}"
                                            ToolTip.Tip="Expand / collapse this collection">
                                        <Panel>
                                            <Path Classes="icon muted sm" Data="{StaticResource Icon.ChevronRight}"
                                                  IsVisible="{Binding !IsExpanded}" />
                                            <Path Classes="icon muted sm" Data="{StaticResource Icon.ChevronDown}"
                                                  IsVisible="{Binding IsExpanded}" />
                                        </Panel>
                                    </Button>
                                    <TextBlock Text="{Binding DisplayValue}"
                                               TextWrapping="Wrap" FontFamily="Monospace"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <!-- Hidden / collapsed: inline, ellipsis -->
                                <TextBlock Text="{Binding Value}" Margin="12,0"
                                           FontSize="10" FontFamily="Monospace" FontStyle="Italic"
                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                           Foreground="{DynamicResource Apx.TextFaint}"
                                           IsVisible="{Binding IsHidden}" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="2*" MinWidth="160" SortMemberPath="ResolvedName" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Resolved" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterResolved, Mode=TwoWay}"
                                                 PlaceholderText="Filter Resolved…" Width="200" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ParamRow">
                            <StackPanel Margin="4,2" VerticalAlignment="Center"
                                        IsVisible="{Binding IsVisible}">
                                <!-- Single resolved item -->
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            IsVisible="{Binding HasSingleResolved}">
                                    <Image Source="{Binding Icon}" Width="28" Height="28"
                                           IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                           RenderOptions.BitmapInterpolationMode="MediumQuality"
                                           VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ResolvedName}" VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <!-- Multi-item array resolution -->
                                <ItemsControl ItemsSource="{Binding ResolvedItems}"
                                              IsVisible="{Binding HasResolvedItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ResolvedItem">
                                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1,0,1">
                                                <Image Source="{Binding Icon}" Width="22" Height="22"
                                                       IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                       RenderOptions.BitmapInterpolationMode="MediumQuality"
                                                       VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
    </DataGrid>

    </DockPanel>

</UserControl>
