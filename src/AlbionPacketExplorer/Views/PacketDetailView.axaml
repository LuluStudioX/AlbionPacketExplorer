<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AlbionPacketExplorer.ViewModels"
             x:Class="AlbionPacketExplorer.Views.PacketDetailView"
             x:DataType="vm:PacketDetailViewModel">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Margin="4,4,4,2"
                   FontWeight="Bold"
                   Text="{Binding Packet, StringFormat='Packet: {0}', FallbackValue='No packet selected'}" />

        <DataGrid ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  RowHeight="36"
                  GridLinesVisibility="Horizontal">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Value"    Command="{Binding CopyValueCommand}" />
                    <MenuItem Header="Copy Row"      Command="{Binding CopyRowCommand}" />
                    <Separator />
                    <MenuItem Header="Copy All Rows" Command="{Binding CopyAllRowsCommand}" />
                    <Separator />
                    <MenuItem Header="Edit Param Name…" Command="{Binding EditParamCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>

                <!-- Key column: "0" bold + "paramName" normal, note shown as tooltip on hover -->
                <DataGridTemplateColumn Header="Key" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ParamRow">
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        VerticalAlignment="Center" Margin="4,0"
                                        ToolTip.Tip="{Binding Note}">
                                <TextBlock Text="{Binding Key}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SchemaName}"
                                           Foreground="#aaaacc" FontSize="13"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding SchemaName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Type"  Binding="{Binding Type}"  Width="100" />
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />

                <!-- Resolved column: icon + text -->
                <DataGridTemplateColumn Header="Resolved" Width="260">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ParamRow">
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        VerticalAlignment="Center" Margin="4,0">
                                <Image Source="{Binding Icon}"
                                       Width="28" Height="28"
                                       IsVisible="{Binding HasResolved}"
                                       RenderOptions.BitmapInterpolationMode="MediumQuality" />
                                <TextBlock Text="{Binding ResolvedName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</UserControl>
