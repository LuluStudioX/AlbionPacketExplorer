<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AlbionPacketExplorer.ViewModels"
             xmlns:views="using:AlbionPacketExplorer.Views"
             xmlns:loc="using:AlbionPacketExplorer.Markup"
             x:Class="AlbionPacketExplorer.Views.PacketDetailView"
             x:DataType="vm:PacketDetailViewModel">

    <DockPanel>

    <!-- Packet-level banner: Photon response status (OperationResponse.ReturnCode + DebugMessage,
         RESPONSE only, error tint when != 0) and REQUEST/RESPONSE pair navigation. -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding HasBanner}"
            Background="{DynamicResource Apx.SurfaceAlt}"
            BorderBrush="{DynamicResource Apx.Border}"
            BorderThickness="0,0,0,1"
            Padding="10,6">
        <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="8"
                        IsVisible="{Binding HasResponseStatus}">
                <TextBlock Text="{loc:T detail.response.returnCode}"
                           Foreground="{DynamicResource Apx.TextMuted}"
                           VerticalAlignment="Center" />
                <Border CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                        Classes.ok="{Binding !ReturnCodeIsError}"
                        Classes.err="{Binding ReturnCodeIsError}">
                    <Border.Styles>
                        <Style Selector="Border.ok">
                            <Setter Property="Background">
                                <SolidColorBrush Color="{DynamicResource Apx.SuccessColor}" Opacity="0.18" />
                            </Setter>
                        </Style>
                        <Style Selector="Border.err">
                            <Setter Property="Background">
                                <SolidColorBrush Color="{DynamicResource Apx.DangerColor}" Opacity="0.18" />
                            </Setter>
                        </Style>
                    </Border.Styles>
                    <TextBlock Text="{Binding ReturnCodeText}"
                               FontFamily="Consolas,Monospace" FontWeight="SemiBold"
                               Foreground="{DynamicResource Apx.Text}" />
                </Border>
            </StackPanel>
            <StackPanel Spacing="2" IsVisible="{Binding HasDebugMessage}">
                <TextBlock Text="{loc:T detail.response.debugMessage}"
                           Foreground="{DynamicResource Apx.TextMuted}" FontSize="11" />
                <TextBlock Text="{Binding DebugMessageText}"
                           FontFamily="Consolas,Monospace" TextWrapping="Wrap"
                           Foreground="{DynamicResource Apx.Text}" />
            </StackPanel>

            <!-- Paired REQUEST/RESPONSE: click to jump to the partner packet. -->
            <Button Classes="ghost" Padding="6,3"
                    HorizontalAlignment="Left"
                    IsVisible="{Binding HasCorrelation}"
                    Command="{Binding GoToCorrelatedCommand}"
                    ToolTip.Tip="{loc:T detail.correlation.tip}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="icon muted sm" Data="{StaticResource Icon.ArrowLeftRight}" />
                    <TextBlock Text="{Binding CorrelatedLabel}"
                               FontFamily="Consolas,Monospace"
                               Foreground="{DynamicResource Apx.Accent}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>

    <TabControl>

        <!-- ═══════════ PARAMS ═══════════ -->
        <TabItem Header="{loc:T detail.tab.params}">
            <DockPanel>

                <!-- Hide preset toolbar -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="4,2,4,4">
                    <TextBox Text="{Binding NewHidePresetName}" Width="130" PlaceholderText="{loc:T detail.hide.placeholder}" FontSize="11" />
                    <Button Classes="iconbtn" Command="{Binding SaveHidePresetCommand}" Padding="6" ToolTip.Tip="{loc:T detail.hide.save.tip}">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Check}" />
                    </Button>
                    <ComboBox ItemsSource="{Binding HidePresets}"
                              SelectedItem="{Binding SelectedHidePreset, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Name}"
                              PlaceholderText="{loc:T detail.hide.load.placeholder}"
                              MinWidth="140" FontSize="11" />
                    <Button Classes="iconbtn" Command="{Binding LoadHidePresetCommand}" Padding="6" ToolTip.Tip="{loc:T detail.hide.apply.tip}">
                        <Path Classes="icon sm" Data="{StaticResource Icon.ChevronRight}" />
                    </Button>
                    <Button Classes="iconbtn" Command="{Binding DeleteHidePresetCommand}" Padding="6" ToolTip.Tip="{loc:T detail.hide.delete.tip}">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Trash}" />
                    </Button>
                    <Button Classes="ghost" Command="{Binding UnhideAllRowsCommand}" Padding="8,4" ToolTip.Tip="{loc:T detail.hide.showAll.tip}">
                        <TextBlock Text="{loc:T common.showAll}" FontSize="11" />
                    </Button>
                </StackPanel>

                <DataGrid x:Name="MainGrid" ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          FontSize="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}"
                          HorizontalScrollBarVisibility="Disabled"
                          GridLinesVisibility="Horizontal">
                    <!-- Density: MinHeight (not fixed RowHeight) so expanded collection rows can grow.
                         Cell FontSize is bound explicitly because DataGrid.FontSize does not cascade
                         to cell content. -->
                    <DataGrid.Styles>
                        <Style Selector="DataGridRow">
                            <Setter Property="MinHeight"
                                    Value="{Binding $parent[Window].((vm:MainViewModel)DataContext).RowHeight, FallbackValue=26}" />
                        </Style>
                        <Style Selector="DataGridCell TextBlock">
                            <Setter Property="FontSize"
                                    Value="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}" />
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{loc:T detail.menu.copyValue}" Command="{Binding CopyValueCommand}" />
                            <MenuItem Header="{loc:T detail.menu.copyRow}"   Command="{Binding CopyRowCommand}" />
                            <MenuItem Header="{loc:T detail.menu.copyAll}"   Command="{Binding CopyAllRowsCommand}" />
                            <Separator />
                            <MenuItem Header="{loc:T detail.menu.viewFull}" Command="{Binding ViewFullValueCommand}" />
                            <MenuItem Header="{loc:T detail.menu.previewResolve}" Command="{Binding PreviewResolveCommand}"
                                      ToolTip.Tip="{loc:T detail.menu.previewResolve.tip}" />
                            <Separator />
                            <MenuItem Header="{loc:T detail.menu.editParam}" Command="{Binding EditParamCommand}"
                                      ToolTip.Tip="{loc:T detail.menu.editParam.tip}" />
                            <MenuItem Header="{loc:T detail.menu.labelValue}" Command="{Binding LabelValueCommand}"
                                      ToolTip.Tip="{loc:T detail.menu.labelValue.tip}" />
                            <MenuItem Header="{loc:T detail.menu.followValue}" Command="{Binding FollowValueCommand}"
                                      ToolTip.Tip="{loc:T detail.menu.followValue.tip}" />
                            <Separator />
                            <MenuItem Header="{loc:T detail.menu.visibility}">
                                <MenuItem Header="{loc:T detail.menu.hideRow}"   Command="{Binding HideRowCommand}" />
                                <MenuItem Header="{loc:T detail.menu.unhideRow}" Command="{Binding UnhideRowCommand}" />
                                <Separator />
                                <MenuItem Header="{loc:T detail.menu.showAll}"   Command="{Binding UnhideAllRowsCommand}" />
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>

                        <DataGridTemplateColumn Width="200" SortMemberPath="Key" CanUserSort="True">
                            <DataGridTemplateColumn.Header>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{loc:T detail.col.key}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                        <Button.Flyout>
                                            <Flyout Placement="Bottom">
                                                <TextBox Text="{Binding $parent[UserControl].DataContext.FilterKey, Mode=TwoWay}"
                                                         PlaceholderText="{loc:T detail.filterKey.placeholder}" Width="180" />
                                            </Flyout>
                                        </Button.Flyout>
                                        <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                                    </Button>
                                </Grid>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:ParamRow">
                                    <Panel VerticalAlignment="Center">
                                        <!-- Normal view -->
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    Margin="4,0"
                                                    ToolTip.Tip="{Binding Note}"
                                                    IsVisible="{Binding IsVisible}">
                                            <TextBlock Text="{Binding Key}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding SchemaName}"
                                                       Foreground="{DynamicResource Apx.TextMuted}" FontSize="13"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding SchemaName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                     Fill="{DynamicResource Apx.TextFaint}"
                                                     ToolTip.Tip="{loc:T detail.source.base.tip}">
                                                <Ellipse.IsVisible>
                                                    <Binding Path="Source" Converter="{x:Static views:ParamSourceConverters.IsBase}" />
                                                </Ellipse.IsVisible>
                                            </Ellipse>
                                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                     Fill="{DynamicResource ThemeAccentBrush}"
                                                     ToolTip.Tip="{loc:T detail.source.user.tip}">
                                                <Ellipse.IsVisible>
                                                    <Binding Path="Source" Converter="{x:Static views:ParamSourceConverters.IsUser}" />
                                                </Ellipse.IsVisible>
                                            </Ellipse>
                                        </StackPanel>
                                        <!-- Hidden / collapsed view -->
                                        <TextBlock Text="{Binding Key}" FontSize="10"
                                                   FontStyle="Italic" Margin="4,0"
                                                   Foreground="{DynamicResource Apx.TextFaint}"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsHidden}" />
                                    </Panel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="110" SortMemberPath="Type" CanUserSort="True">
                            <DataGridTemplateColumn.Header>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{loc:T detail.col.type}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                        <Button.Flyout>
                                            <Flyout Placement="Bottom">
                                                <TextBox Text="{Binding $parent[UserControl].DataContext.FilterType, Mode=TwoWay}"
                                                         PlaceholderText="{loc:T detail.filterType.placeholder}" Width="160" />
                                            </Flyout>
                                        </Button.Flyout>
                                        <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                                    </Button>
                                </Grid>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:ParamRow">
                                    <TextBlock Text="{Binding Type}" Margin="12,0" VerticalAlignment="Center"
                                               IsVisible="{Binding IsVisible}"
                                               Foreground="{DynamicResource Apx.Text}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*" MinWidth="120" SortMemberPath="Value" CanUserSort="True">
                            <DataGridTemplateColumn.Header>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{loc:T detail.col.value}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                        <Button.Flyout>
                                            <Flyout Placement="Bottom">
                                                <TextBox Text="{Binding $parent[UserControl].DataContext.FilterValue, Mode=TwoWay}"
                                                         PlaceholderText="{loc:T detail.filterValue.placeholder}" Width="200" />
                                            </Flyout>
                                        </Button.Flyout>
                                        <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                                    </Button>
                                </Grid>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:ParamRow">
                                    <Panel VerticalAlignment="Center">
                                        <!-- Normal: collections show a chevron to expand inline;
                                             the value text collapses to "[N items]" until expanded. -->
                                        <StackPanel Orientation="Horizontal" Spacing="2" Margin="8,4"
                                                    IsVisible="{Binding IsVisible}">
                                            <Button Classes="iconbtn" Padding="2" Width="20" Height="20"
                                                    VerticalAlignment="Top"
                                                    Command="{Binding $parent[UserControl].DataContext.ToggleRowExpandCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding IsCollection}"
                                                    ToolTip.Tip="{loc:T detail.expand.tip}">
                                                <Panel>
                                                    <Path Classes="icon muted sm" Data="{StaticResource Icon.ChevronRight}"
                                                          IsVisible="{Binding !IsExpanded}" />
                                                    <Path Classes="icon muted sm" Data="{StaticResource Icon.ChevronDown}"
                                                          IsVisible="{Binding IsExpanded}" />
                                                </Panel>
                                            </Button>
                                            <TextBlock Text="{Binding DisplayValue}"
                                                       TextWrapping="Wrap" FontFamily="Monospace"
                                                       VerticalAlignment="Center" />
                                            <Border CornerRadius="3" Padding="5,1" VerticalAlignment="Center"
                                                    IsVisible="{Binding HasEnumLabel}"
                                                    Background="{DynamicResource Apx.SurfaceAlt}"
                                                    ToolTip.Tip="{loc:T detail.enumLabel.tip}">
                                                <TextBlock Text="{Binding EnumLabel}" FontSize="11"
                                                           Foreground="{DynamicResource Apx.Accent}" />
                                            </Border>
                                        </StackPanel>
                                        <!-- Hidden / collapsed: inline, ellipsis -->
                                        <TextBlock Text="{Binding Value}" Margin="12,0"
                                                   FontSize="10" FontFamily="Monospace" FontStyle="Italic"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                   Foreground="{DynamicResource Apx.TextFaint}"
                                                   IsVisible="{Binding IsHidden}" />
                                    </Panel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <!-- ═══════════ RESOLVED ═══════════ -->
        <TabItem Header="{loc:T detail.tab.resolved}">
            <Panel>
                <!-- Empty state -->
                <TextBlock Text="{loc:T detail.resolved.empty}"
                           Foreground="{DynamicResource Apx.TextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" Margin="24"
                           IsVisible="{Binding !HasAnyResolved}" />

                <ScrollViewer IsVisible="{Binding HasAnyResolved}">
                    <ItemsControl ItemsSource="{Binding ResolvedRows}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ParamRow">
                                <Border Classes="card" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Apx.Accent}" />
                                            <TextBlock Text="{Binding SchemaName}"
                                                       Foreground="{DynamicResource Apx.TextMuted}"
                                                       IsVisible="{Binding SchemaName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                        <!-- Single resolved item -->
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    IsVisible="{Binding HasSingleResolved}">
                                            <Image Source="{Binding Icon}" Width="32" Height="32"
                                                   IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                   RenderOptions.BitmapInterpolationMode="MediumQuality"
                                                   VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ResolvedName}" VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <!-- Multi-item array resolution -->
                                        <ItemsControl ItemsSource="{Binding ResolvedItems}"
                                                      IsVisible="{Binding HasResolvedItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ResolvedItem">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1">
                                                        <Image Source="{Binding Icon}" Width="24" Height="24"
                                                               IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                               RenderOptions.BitmapInterpolationMode="MediumQuality"
                                                               VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Panel>
        </TabItem>

        <!-- ═══════════ DIFF (request vs paired response) ═══════════ -->
        <TabItem Header="{loc:T detail.tab.diff}">
            <Panel>
                <!-- Empty state: no paired packet -->
                <TextBlock Text="{loc:T detail.diff.empty}"
                           Foreground="{DynamicResource Apx.TextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" Margin="24"
                           IsVisible="{Binding !HasDiff}" />

                <DockPanel IsVisible="{Binding HasDiff}">
                    <TextBlock DockPanel.Dock="Bottom" Text="{loc:T detail.diff.legend}"
                               Foreground="{DynamicResource Apx.TextMuted}" FontSize="11"
                               Margin="8,4" TextWrapping="Wrap" />

                    <Grid DockPanel.Dock="Top" ColumnDefinitions="220,*,*" Margin="8,6,8,2">
                        <TextBlock Grid.Column="0" Text="{loc:T detail.diff.col.key}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{loc:T detail.diff.col.request}" FontWeight="SemiBold" Margin="6,0" />
                        <TextBlock Grid.Column="2" Text="{loc:T detail.diff.col.response}" FontWeight="SemiBold" Margin="6,0" />
                    </Grid>

                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding DiffRows}" Margin="8,0,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ParamDiffRow">
                                    <Border CornerRadius="3" Padding="4,2" Margin="0,1"
                                            Classes.resp="{Binding IsRightOnly}"
                                            Classes.req="{Binding IsLeftOnly}"
                                            Classes.chg="{Binding IsChanged}">
                                        <Border.Styles>
                                            <Style Selector="Border.resp">
                                                <Setter Property="Background">
                                                    <SolidColorBrush Color="{DynamicResource Apx.SuccessColor}" Opacity="0.16" />
                                                </Setter>
                                            </Style>
                                            <Style Selector="Border.chg">
                                                <Setter Property="Background">
                                                    <SolidColorBrush Color="{DynamicResource Apx.AccentColor}" Opacity="0.16" />
                                                </Setter>
                                            </Style>
                                            <Style Selector="Border.req">
                                                <Setter Property="Background">
                                                    <SolidColorBrush Color="{DynamicResource Apx.DangerColor}" Opacity="0.12" />
                                                </Setter>
                                            </Style>
                                        </Border.Styles>
                                        <Grid ColumnDefinitions="220,*,*">
                                            <TextBlock Grid.Column="0" Text="{Binding KeyDisplay}"
                                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="1" Text="{Binding LeftValue}"
                                                       FontFamily="Consolas,Monospace" Margin="6,0"
                                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Text="{Binding RightValue}"
                                                       FontFamily="Consolas,Monospace" Margin="6,0"
                                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Panel>
        </TabItem>

        <!-- ═══════════ RAW JSON ═══════════ -->
        <TabItem Header="{loc:T detail.tab.rawJson}">
            <TextBox Text="{Binding RawJson}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas,Monospace"
                     FontSize="12"
                     BorderThickness="0"
                     Background="Transparent"
                     VerticalAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </TabItem>

    </TabControl>

    </DockPanel>

</UserControl>
