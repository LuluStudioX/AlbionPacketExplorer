<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AlbionPacketExplorer.ViewModels"
             xmlns:views="using:AlbionPacketExplorer.Views"
             xmlns:loc="using:AlbionPacketExplorer.Markup"
             x:Class="AlbionPacketExplorer.Views.PacketListView"
             x:DataType="vm:PacketListViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Spacing="2" Margin="4,4,4,2">
            <!-- Filter row -->
            <StackPanel Orientation="Horizontal" Spacing="6">

                <!-- Filter edit button — shows label or placeholder, opens flyout to edit query -->
                <Button Classes="ghost" Padding="8,4" MinWidth="120"
                        ToolTip.Tip="{loc:T list.filter.edit.tip}">
                    <Button.Flyout>
                        <Flyout Placement="Bottom" ShowMode="TransientWithDismissOnPointerMoveAway">
                            <TextBox Text="{Binding FilterQuery, Mode=TwoWay}"
                                     PlaceholderText="{loc:T list.filter.placeholder}"
                                     MinWidth="420" />
                        </Flyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource Icon.Search}" />
                        <TextBlock Text="{Binding FilterDisplayText}" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Classes="iconbtn" Command="{Binding ClearFilterCommand}"
                        ToolTip.Tip="{loc:T list.filter.clear.tip}">
                    <Path Classes="icon" Data="{StaticResource Icon.X}" />
                </Button>
                <ToggleButton IsChecked="{Binding SortUnknownFirst, Mode=TwoWay}" Padding="8,4"
                              ToolTip.Tip="{loc:T list.unknownFirst.tip}">
                    <TextBlock Text="{loc:T list.unknownFirst}" FontSize="11" VerticalAlignment="Center" />
                </ToggleButton>
                <TextBlock VerticalAlignment="Center" Text="{Binding CountText}"
                           Foreground="{DynamicResource Apx.TextMuted}" />
            </StackPanel>
            <!-- Preset row -->
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBox Text="{Binding NewPresetName}" Width="140" PlaceholderText="{loc:T list.preset.placeholder}" />
                <Button Classes="iconbtn" Command="{Binding SavePresetCommand}"
                        ToolTip.Tip="{loc:T list.preset.save.tip}">
                    <Path Classes="icon" Data="{StaticResource Icon.Check}" />
                </Button>
                <ComboBox ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                          DisplayMemberBinding="{Binding Name}"
                          PlaceholderText="{loc:T list.preset.load.placeholder}"
                          MinWidth="160" />
                <Button Classes="iconbtn" Command="{Binding LoadPresetCommand}"
                        ToolTip.Tip="{loc:T list.preset.apply.tip}">
                    <Path Classes="icon" Data="{StaticResource Icon.ChevronRight}" />
                </Button>
                <Button Classes="iconbtn" Command="{Binding DeletePresetCommand}"
                        ToolTip.Tip="{loc:T list.preset.delete.tip}">
                    <Path Classes="icon" Data="{StaticResource Icon.Trash}" />
                </Button>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="MainGrid" ItemsSource="{Binding Packets}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  SelectionMode="Extended"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  FontSize="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Styles>
                <Style Selector="DataGridRow">
                    <Setter Property="MinHeight"
                            Value="{Binding $parent[Window].((vm:MainViewModel)DataContext).RowHeight, FallbackValue=26}" />
                </Style>
                <Style Selector="DataGridCell TextBlock">
                    <Setter Property="FontSize"
                            Value="{Binding $parent[Window].((vm:MainViewModel)DataContext).GridFontSize, FallbackValue=12}" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{loc:T list.menu.copyParams}"   Command="{Binding CopyParamSummaryCommand}" />
                    <MenuItem Header="{loc:T list.menu.copyJson}"  Command="{Binding CopyAsJsonCommand}" />
                    <Separator />
                    <MenuItem Header="{loc:T list.menu.diffSelected}" Click="OnDiffSelectedClick" />
                    <Separator />
                    <MenuItem Header="{loc:T list.menu.unknownFirst}"
                              IsChecked="{Binding SortUnknownFirst, Mode=TwoWay}"
                              ToggleType="CheckBox" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>

                <DataGridTemplateColumn Width="100" SortMemberPath="Timestamp" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{loc:T list.col.timestamp}" VerticalAlignment="Center" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:PacketRow">
                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                       Margin="12,0" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="90" SortMemberPath="Kind" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{loc:T list.col.kind}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterKind, Mode=TwoWay}"
                                                 PlaceholderText="{loc:T list.filterKind.placeholder}" Width="160" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:PacketRow">
                            <TextBlock Text="{Binding Kind}" Margin="12,0" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="55" SortMemberPath="Code" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{loc:T list.col.code}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterCode, Mode=TwoWay}"
                                                 PlaceholderText="{loc:T list.filterCode.placeholder}" Width="160" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:PacketRow">
                            <TextBlock Text="{Binding Code}" Margin="12,0" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="220" SortMemberPath="EventName" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{loc:T list.col.name}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterName, Mode=TwoWay}"
                                                 PlaceholderText="{loc:T list.filterName.placeholder}" Width="200" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:PacketRow">
                            <TextBlock Margin="12,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       Text="{Binding EventName}"
                                       Opacity="{Binding IsKnown, Converter={x:Static views:ViewConverters.BoolToOpacity}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="60" SortMemberPath="KeyCount" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{loc:T list.col.keys}" VerticalAlignment="Center" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:PacketRow">
                            <TextBlock Text="{Binding KeyCount}" Margin="12,0" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="*" SortMemberPath="ParamSummary" CanUserSort="True">
                    <DataGridTemplateColumn.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{loc:T list.col.params}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" Padding="2" Width="22" Height="22" VerticalAlignment="Center">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <TextBox Text="{Binding $parent[UserControl].DataContext.FilterParams, Mode=TwoWay}"
                                                 PlaceholderText="{loc:T list.filterParams.placeholder}" Width="240" />
                                    </Flyout>
                                </Button.Flyout>
                                <Path Classes="icon muted sm" Data="{StaticResource Icon.Search}" />
                            </Button>
                        </Grid>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:PacketRow">
                            <TextBlock Text="{Binding ParamSummary}" Margin="12,0" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</UserControl>
