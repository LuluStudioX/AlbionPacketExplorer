<controls:ApxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
        xmlns:vm="using:AlbionPacketExplorer.ViewModels"
        xmlns:loc="using:AlbionPacketExplorer.Markup"
        x:Class="AlbionPacketExplorer.Views.ShareDigestWindow"
        x:DataType="vm:ShareDigestViewModel"
        Icon="/Assets/app-icon.ico"
        Title="{loc:T digest.title}"
        Width="640" Height="560"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="{loc:T digest.intro}" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource Apx.TextMuted}" />

            <StackPanel Orientation="Horizontal" Spacing="14">
                <RadioButton GroupName="DigestMode" IsChecked="{Binding UnknownOnly}"
                             Content="{loc:T digest.mode.unknown}"
                             ToolTip.Tip="{loc:T digest.mode.unknown.tip}" FontSize="12" />
                <RadioButton GroupName="DigestMode" IsChecked="{Binding !UnknownOnly}"
                             Content="{loc:T digest.mode.all}"
                             ToolTip.Tip="{loc:T digest.mode.all.tip}" FontSize="12" />
            </StackPanel>

            <TextBlock Text="{Binding SummaryText}" FontSize="12"
                       Foreground="{DynamicResource Apx.Text}" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,10,0,0">
            <TextBlock Text="{loc:T digest.privacy}" TextWrapping="Wrap" FontSize="11"
                       Foreground="{DynamicResource Apx.TextMuted}" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12"
                           VerticalAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource Apx.TextMuted}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Classes="ghost" Content="{loc:T digest.save}" Command="{Binding SaveCommand}" />
                    <Button Classes="ghost" Content="{loc:T digest.copy}" Command="{Binding CopyCommand}" />
                    <Button Classes="success" Content="{loc:T digest.upload}" Command="{Binding UploadCommand}"
                            ToolTip.Tip="{loc:T digest.upload.tip}" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <Border Margin="0,10,0,0" BorderThickness="1" CornerRadius="4"
                BorderBrush="{DynamicResource Apx.Border}">
            <TextBox Text="{Binding PreviewText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True"
                     FontFamily="Consolas,Monospace" FontSize="11" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Border>

    </DockPanel>
</controls:ApxWindow>
