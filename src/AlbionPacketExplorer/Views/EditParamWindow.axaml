<controls:ApxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls"
        xmlns:vm="using:AlbionPacketExplorer.ViewModels"
        xmlns:loc="using:AlbionPacketExplorer.Markup"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        x:Class="AlbionPacketExplorer.Views.EditParamWindow"
        x:DataType="vm:EditParamViewModel"
        Title="{Binding Title}"
        Width="420" Height="400"
        MinWidth="320" MinHeight="380"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="14">

        <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{loc:T editParam.paramName}" FontSize="12" Foreground="Gray" VerticalAlignment="Center" />
                <Border Background="{DynamicResource ThemeAccentBrush}" CornerRadius="3" Padding="4,1"
                        IsVisible="{Binding SourceIsBase}" ToolTip.Tip="{loc:T editParam.badge.base.tip}">
                    <TextBlock Text="{loc:T editParam.badge.base}" FontSize="10" Foreground="{DynamicResource Apx.AccentText}" />
                </Border>
                <Border Background="{DynamicResource HighlightBrush}" CornerRadius="3" Padding="4,1"
                        IsVisible="{Binding SourceIsUser}" ToolTip.Tip="{loc:T editParam.badge.user.tip}">
                    <TextBlock Text="{loc:T editParam.badge.user}" FontSize="10" Foreground="{DynamicResource HighlightForegroundBrush}" />
                </Border>
            </StackPanel>
            <TextBox x:Name="ParamNameBox"
                     Text="{Binding ParamName}"
                     PlaceholderText="{loc:T editParam.paramName.placeholder}"
                     MaxLength="64" />
            <!-- Suggestions float in a Popup so they overlay the form below instead of
                 reflowing it (which on a fixed-size window pushed the buttons off-screen). -->
            <Popup IsOpen="{Binding ShowSuggestions}"
                   PlacementTarget="{Binding #ParamNameBox}"
                   Placement="BottomEdgeAlignedLeft"
                   HorizontalOffset="0" VerticalOffset="2"
                   IsLightDismissEnabled="False">
            <Border Background="{DynamicResource Apx.Card}"
                    BorderBrush="{DynamicResource ThemeAccentBrush}"
                    BorderThickness="1" CornerRadius="4" MaxHeight="160"
                    MinWidth="{Binding #ParamNameBox.Bounds.Width}"
                    ClipToBounds="True">
                <ListBox x:Name="SuggestionList"
                         ItemsSource="{Binding Suggestions}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionChanged="OnSuggestionSelected">
                    <ListBox.Styles>
                        <Style Selector="ListBox">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBox > ScrollViewer">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Padding" Value="6,4" />
                            <Setter Property="Foreground" Value="{DynamicResource Apx.Text}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FontSize" Value="12" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}" />
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </Border>
            </Popup>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="{loc:T editParam.note}" FontSize="12" Foreground="Gray" />
            <TextBox Text="{Binding Note}"
                     PlaceholderText="{loc:T editParam.note.placeholder}"
                     MaxLength="256"
                     AcceptsReturn="False" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="{loc:T editParam.resolveAs}" FontSize="12" Foreground="Gray" />
            <ComboBox SelectedItem="{Binding ResolveAs}" HorizontalAlignment="Stretch"
                      ItemsSource="{x:Static vm:EditParamViewModel.ResolveAsOptions}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="{loc:T editParam.clearOverride}"
                    Command="{Binding ClearOverrideCommand}"
                    Foreground="Gray" />
            <Button Content="{loc:T editParam.save}"
                    Command="{Binding SaveCommand}"
                    Background="#2a5a2a" Foreground="White" />
        </StackPanel>

    </StackPanel>
</controls:ApxWindow>
