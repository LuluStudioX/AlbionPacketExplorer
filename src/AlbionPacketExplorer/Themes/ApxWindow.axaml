<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AlbionPacketExplorer.Controls">

    <!--
      ApxWindow uses the native OS title bar with a themed client area. We only set
      the surface colors here; the default Window template provides the structure.
    -->
    <Style Selector="controls|ApxWindow">
        <Setter Property="Background" Value="{DynamicResource Apx.Bg}" />
        <Setter Property="Foreground" Value="{DynamicResource Apx.Text}" />
        <Setter Property="FontSize" Value="{DynamicResource Apx.Font.Sm}" />
    </Style>

</Styles>
